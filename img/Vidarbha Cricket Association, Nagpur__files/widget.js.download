	function jwPlayerNextFrame(){
		 if (jwplayerObj) {
			jwplayerObj.pause();
			var elapsed1 = jwplayerObj.getPosition();
			elapsed1 = elapsed1 + 0.04;
			jwplayerObj.seek(elapsed1);
			
		  }
	}
	function jwPlayerPrevFrame(){
		 if (jwplayerObj) {
			jwplayerObj.pause();
			var elapsed1 = jwplayerObj.getPosition();
			elapsed1 = elapsed1 - 0.04;
			jwplayerObj.seek(elapsed1);
			
		  }
	}
	function jwPlayerPlaylist(){
		$(".playerInnerWrap.listWarp").addClass("disableClick");
		if(!mcVideoPlayListClick)
		{
			mcVideoPlayListClick = true;
			$(".playlistWrap").removeClass("inactive");
			if($(".playlistWrap").hasClass("active")){
				$(".playlistWrap").removeClass("active");
				setTimeout(function(){
					$(".playlistWrap").addClass("inactive");
					$(".playlistWrap").removeClass("active");	
				},1900);
				
			}
			else
			{
				$(".playlistWrap").addClass("active");
				$(".playlistWrap").removeClass("inactive");
			}

			setTimeout(function(){
				mcVideoPlayListClick = false;
				$(".playerInnerWrap.listWarp").removeClass("disableClick");
				console.log("here");
			},2000);
		}

	}
	
	function jwPlayerDownload(){
		  if($(".downloadWarp").hasClass("active")){
