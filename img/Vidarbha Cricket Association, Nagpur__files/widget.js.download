><p class="ppText">{{postMatchCommentary}}</p></div> </div></div><!-- End of commentary block--><!-- Match Details - Mobile View Only --><div id="matchDetailsContent" class="mcTabContent"><div class="col s12 m12 l12"> <div class="widget matchDetails"><h4 class="widgetTitle">Match Details</h4><div class="widgetContent"> <ul> <li ng-if="selectedCompetition.CompetitionName != \'All Live Matches\' && (matchSummary.CompetitionName == undefined || matchSummary.CompetitionName==\'\')"><span>Tournament</span><span>{{selectedCompetition.CompetitionName}}</span></li> <li ng-if="(matchSummary.CompetitionName != undefined && matchSummary.CompetitionName!=\'\')"><span>Tournament</span><span>{{matchSummary.CompetitionName}}</span></li> <li ng-if="matchSummary.MatchName!=\'\'"><span>Match</span><span ng-bind="matchSummary.MatchName"></span></li> <li ng-if="matchSummary.TossDetails!=\'\'"><span>Toss win</span><span ng-bind="matchSummary.TossDetails"></span></li> <li ng-if="matchSummary.GroundName!=\'\'"><span>Venue</span><span ng-bind="matchSummary.GroundName"></span></li> <li ng-if="matchSummary.Umpire1Name!=\'\' || matchSummary.Umpire2Name!=\'\' || matchSummary.Umpire3Name!=\'\'"> <span>Umpires</span> <span> <text ng-if="matchSummary.Umpire1Name!=\'\'">{{matchSummary.Umpire1Name}}</text> <text ng-if="matchSummary.Umpire2Name!=\'\'"> , {{matchSummary.Umpire2Name}}</text> <text ng-if="matchSummary.Umpire3Name!=\'\'"> , {{matchSummary.Umpire3Name}}</text> </span> </li> <li ng-if="matchSummary.Referee!=\'\'"><span>Referee</span><span>{{matchSummary.Referee}}</span></li> <!-- <li ng-if="(matchSummary.Scorer1Name!=undefined && matchSummary.Scorer1Name!=\'\') || (matchSummary.Scorer2Name!=undefined && matchSummary.Scorer2Name!=\'\')"><span>Scorer</span> <span> <text ng-if="matchSummary.Scorer1Name!=\'\'">{{matchSummary.Scorer1Name}}</text> <text ng-if="matchSummary.Scorer2Name!=\'\'"> , {{matchSummary.Scorer2Name}}</text> </span> </li> --> <li ng-if="matchSummary.MOM!=undefined && matchSummary.MOM!=\'\'"><span>MOM</span><span>{{matchSummary.MOM}}</span></li> </ul> <div class="innDetails hide"> <h6>1<sup>st</sup> innings</h6> <ul> <li><span>Swastic Union Cricket Club(2)</span></li> <li>Powerplay: 38 runs, 2 wickets</li> <li>Swastic Union Cricket Club(2): 50 runs in 8.3 overs</li> <li>Sunrisers Hyderabad: 100 runs in 14.2 overs</li> <li>4th Wicket: 50 runs in 37 balls (Kane Williamson 27, Shakib Al Hasan 22)</li> <li>Kane Williamson: 50 off 35 balls (4 x fours, 2 x sixes)</li> <li>Innings Break: Sunrisers Hyderabad - 146/10 in 20 overs</li> </ul> <h6>2nd innings</h6> <ul> <li><span>Bangalore United Cricket Club(1)</span></li> <li>Powerplay: 38 runs, 2 wickets</li> <li>Swastic Union Cricket Club(2): 50 runs in 8.3 overs</li> <li>Sunrisers Hyderabad: 100 runs in 14.2 overs</li> <li>4th Wicket: 50 runs in 37 balls (Kane Williamson 27, Shakib Al Hasan 22)</li> <li>Kane Williamson: 50 off 35 balls (4 x fours, 2 x sixes)</li> <li>Innings Break: Sunrisers Hyderabad - 146/10 in 20 overs</li> </ul> </div></div><!-- END .matchDetails --> </div> </div></div><!-- Playing XI - Mobile View Only --><div id="playingXIContent" class="mcTabContent"><div class="col s12 m12 l12"><div class="widget playingXI" ng-show="squad"><h4 class="widgetTitle">playing XI</h4><div class="widgetContent"> <div class="team"> <a><span class="tLogo"> <img ng-if="isNotNull(squadATeamLogo)" ng-src="{{squadATeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{matchSummary.FirstBattingTeamName}}" /><img ng-if="!isNotNull(squadATeamLogo)" ng-src="{{basepath}}images/default-team-logo.png" alt="{{squadATeamName}}" /> </span>{{squadATeamName}}</a><ul class="squadList"><li ng-repeat="(key ,list) in squadA"><div class="squadListPlayerName"><span>{{list.PlayerName}}</span></div></li></ul> </div> <div class="team"> <a> <span class="tLogo"> <img ng-if="isNotNull(squadBTeamLogo)" ng-src="{{squadBTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{matchSummary.FirstBattingTeamName}}" /><img ng-if="!isNotNull(squadBTeamLogo)" ng-src="{{basepath}}images/default-team-logo.png" alt="{{squadATeamName}}" /> </span>{{squadBTeamName}}</a> <ul class="squadList"><li ng-repeat="(key ,list) in squadB"><div class="squadListPlayerName"><span>{{list.PlayerName}}</span></div></li></ul> </div></div><!-- END .playingXI --> </div> </div></div><!-- Graph Section --><div id="wagonWheelContent" class="mcTabContent"> <div class="col s12 m12 l12 settingWrap uniform-grid"> <select class="mcSelectDefault inningsList innsFilter" data-ng-options="innData.name for innData in inningsList track by innData.innNo" data-ng-model="selectedInnWagonList" data-ng-change="constructScoreCard(matchSummary.MatchID,\'dropdownInnChangeWagon\',\'innchange\')"> </select> <select class="mcSelectDefault batsmenFilter" data-ng-options="innData.PlayerName for innData in indvBattingData track by innData.PlayerID" data-ng-model="selectedBatPlayer" data-ng-change="viewIndvBatData()"> <option value="">All Batsmen</option> </select> <select class="mcSelectDefault bowlerFilter" data-ng-options="innData.PlayerName for innData in indvBowlingData track by innData.PlayerID" data-ng-model="selectedBowlPlayer" data-ng-change="viewIndvBowlData()"> <option value="">All Bowlers</option> </select></div><div id="wagonwheelContainer"><div class="graphCircle" id="Wagonwheel" style=\'width: 620px; height: 620px;background-position: 96px 83px;background-size:inherit;\'></div> <div id=\'mob_Wagonwheel\' style=\'width: 300px; height: 300px;\'> </div></div><!-- <div class="graphCircle"><img src="images/rhbwagon.png" /></div> --><div class="switch_data"><div class="batStyle"><div class="wagonSide offSide active" data-val="offside"><h6 ng-if="!wagonLHBView">Off Side</h6><h6 ng-if="wagonLHBView">On Side</h6><span>Runs - <i id="offSideTotal"></i> (<i id="offSidePercent"></i>)</span></div><div class="wagonSide onSide" data-val="onside"><h6 ng-if="!wagonLHBView">On Side</h6><h6 ng-if="wagonLHBView">Off Side</h6><span>Runs - <i id="onSideTotal"></i> (<i id="onSidePercent"></i>)</span></div></div><div class="wagonData uniform-grid js-wagonSideElements offside"><div class="side"><h6 ng-if="!wagonLHBView">Third Man</h6><h6 ng-if="wagonLHBView">Fine Leg</h6><span>Runs<i id="thirdmanTotal"></i></span><span>BDRY<i id="thirdmanBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Point</h6><h6 ng-if="wagonLHBView">Square Leg</h6><span>Runs<i id="pointTotal"></i></span><span>BDRY<i id="pointsBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Cover</h6><h6 ng-if="wagonLHBView">Mid Wicket</h6><span>Runs<i id="coversTotal"></i></span><span>BDRY<i id="coverBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Long Off</h6><h6 ng-if="wagonLHBView">Long On</h6><span>Runs<i id="longoffTotal"></i></span><span>BDRY<i id="longOffBdry"></i></span> </div></div><div class="wagonData uniform-grid js-wagonSideElements onside hide"> <div class="side"><h6 ng-if="!wagonLHBView">Fine Leg</h6><h6 ng-if="wagonLHBView">Third Man</h6><span>Runs<i id="fineLegTotal"></i></span><span>BDRY<i id="fineLegBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Square Leg</h6><h6 ng-if="wagonLHBView">Point</h6><span>Runs<i id="squarelegTotal"></i></span><span>BDRY<i id="squarelegBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Mid Wicket</h6><h6 ng-if="wagonLHBView">Cover</h6><span>Runs<i id="midwicketTotal"></i></span><span>BDRY<i id="midwicketBdry"></i></span> </div> <div class="side"><h6 ng-if="!wagonLHBView">Long On</h6><h6 ng-if="wagonLHBView">Long Off</h6><span>Runs<i id="longonTotal"></i></span><span>BDRY<i id="longonBdry"></i></span> </div> </div><div id="wagon-panel"><ul class="wagon-points uniform-grid"><li class="all"><span>All</span></li><li class="wc1"><span>1s</span><i class="ng-binding">{{wagonWheelSummary.Ones}}</i></li><li class="wc2"><span>2s</span><i class="ng-binding">{{wagonWheelSummary.Twos}}</i></li><li class="wc3"><span>3s</span><i class="ng-binding">{{wagonWheelSummary.Threes}}</i></li><li class="wc4"><span>4s</span><i class="ng-binding">{{wagonWheelSummary.Fours}}</i></li><li class="wc6"><span>6s</span><i class="ng-binding">{{wagonWheelSummary.Sixes}}</i></li></ul></div></div></div><!--Manhattan & Worm--><div id="mwpage" class="mcTabContent"><div id="manhattan-wrapper" class="scorecardItems active"><div class="scorecardHeader" ng-show="matchSummary.MatchType == \'Multi Day\'"><select class="mcSelectDefault inningsList wagoninningsList" data-ng-options="innData.name for innData in inningsList track by innData.innNo" data-ng-model="selectedWInnList" data-ng-change="constructScoreCard(matchSummary.MatchID,\'dropdownWInnChange\',\'innchange\')"></select></div> <div id="smipl-graphsplots"> <div class="manhattonwidgetTitle">Manhattan</div> <div class="manhattonwidgetLegend manhattonLegend" ng-show="matchSummary.MatchType != \'Multi Day\'"> <div class="manhattonwidgetLegendItem teamALegendItem" ng-style="{\'color\':\'#2C82C9\'}" ng-if="currentInnText == \'Innings2\' || currentInnText == \'Innings4\'"> {{matchSummary.FirstBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamALegendItem" ng-style="{\'color\':\'#2C82C9\'}" ng-if="currentInnText == \'Innings1\' || currentInnText == \'Innings3\'"> {{matchSummary.FirstBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamBLegendItem" ng-style="{\'color\':\'#D14841\'}" ng-if="currentInnText == \'Innings2\' || currentInnText == \'Innings4\'"> {{matchSummary.SecondBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamBLegendItem" ng-style="{\'color\':\'#D14841\'}" ng-if="currentInnText == \'Innings1\' || currentInnText == \'Innings3\'"> {{matchSummary.SecondBattingTeam}} </div> </div> <div id="smipl-manhattan-wrap"><div id="smipl-manhattan" class="smipl-graph-yes"></div></div> <div class="manhattan-nav"> <div class="MHprev" start="" end=""></div> <div class="MHnext" start="" end=""></div> </div> <div class="manhattonwidgetTitle">Worm</div> <div class="manhattonwidgetLegend manhattonLegend" ng-show="matchSummary.MatchType != \'Multi Day\'"> <div class="manhattonwidgetLegendItem teamALegendItem" ng-style="{\'color\':\'#2C82C9\'}" ng-if="currentInnText == \'Innings2\' || currentInnText == \'Innings4\'"> {{matchSummary.FirstBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamALegendItem" ng-style="{\'color\':\'#2C82C9\'}" ng-if="currentInnText == \'Innings1\' || currentInnText == \'Innings3\'"> {{matchSummary.FirstBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamBLegendItem" ng-style="{\'color\':\'#D14841\'}" ng-if="currentInnText == \'Innings2\' || currentInnText == \'Innings4\'"> {{matchSummary.SecondBattingTeam}} </div> <div class="manhattonwidgetLegendItem teamBLegendItem" ng-style="{\'color\':\'#D14841\'}" ng-if="currentInnText == \'Innings1\' || currentInnText == \'Innings3\'"> {{matchSummary.SecondBattingTeam}} </div> </div> <div id="smipl-worm" class="smipl-graph-yes"></div> </div> <div class="smipl-chart-parent"> <div class="smipl-chart-popup"> <span class="tooltip-span"> <div class="tool-center"> <div class="tool-value"> </div> </div> </span> </div> </div> </div> </div><!--End of Manhattan & Worm--><!--Analytics--><div id="analytPage" class="mcTabContent"> <div id="spotential_widget" ng-show="showSP" class="widget momentum_widget"> <h1 class="widgetTitle">Score Potential</h1> <div class="widget_header potential"> <div class="tabBlock"> <div class="xl-12 medium-12 small-12 smcpl-columns tabBlock no-padding"> <div class="active tabItem potenTab" data-inn="1" ng-click="changePotential(\'SP\')" title="Estimates the average score potential of the team based upon the current situation and its players">Score Potential </div> <div class="tabItem inn2 winlossTab" ng-show="showWLP" data-inn="2" ng-click="changePotential(\'WLP\')" title="Brings perspective to the chances of winning for the team based upon the current situation and its players.">Win/Loss Probability</div> <i class="fa fa-facebook-square social_widgetShareIcon" aria-hidden="true"></i> <i class="fa fa-twitter-square social_widgetShareIcon" aria-hidden="true"></i> </div> <div class="two-teams"> <p class="legent_li lengent_team1"></p></div> <div class="potentialDetails"> <div class="potentialTeam" ng-bind="potentialTeam"></div> <div class="">Score Potential : <span class="potentialScore">{{potentialScore}}</span></div> <div class="potentialTeamScore">Score : {{potentialTeamCurrentScore}}/{{potentialTeamCurrentWicket}}</div> </div> </div> </div> <div class="tab_container"> <div id="potentialChart" class="widget_items"></div> </div> <div id="spshare" class="inactive" style="float: left;width: 100%;position:relative;"> <div class="matchsumInfo">{{matchSummary.MatchName}} - {{matchSummary.GroundName}}, {{matchSummary.MatchDate}}</div> <div class="matchsum"></div> <h1 class="widgetTitle">Score Potential</h1> <div class="potentialDetails"> <div class="potentialTeam" ng-bind="potentialTeam"></div> <div class="">Score Potential : <span class="potentialScore">{{potentialScore}}</span></div> <div class="potentialTeamScore">Score : {{potentialTeamCurrentScore}}/{{potentialTeamCurrentWicket}}</div> </div> <img class="spshareimg" src= "" /> </div> </div> <div class="widget momentum_widget" ng-show="showWLP" id="wlProb_widget"> <h1 class="widgetTitle">Win/Loss Probability</h1> <div class="wlpDetails inactive"> <div class="wlpTeam">{{wlpT1}} : {{wlpT1Score}}%</div> <div class="wlpTeam">{{wlpT2}} : {{wlpT2Score}}%</div> <!-- <div class="potentialTeamScore">Score : {{wlpTeamCurrentScore}}/{{wlpTeamCurrentWicket}}</div> --> </div> <div class="widget_header potential"> <div class="tabBlock"> <div class="xl-12 medium-12 small-12 smcpl-columns tabBlock no-padding"> <div class="tabItem potenTab" data-inn="1" ng-click="changePotential(\'SP\')" title="Estimates the average score potential of the team based upon the current situation and its players">Score Potential </div> <div class="active tabItem inn2 winlossTab" ng-show="showWLP" ng-click="changePotential(\'WLP\')" data-inn="2" title="Brings perspective to the chances of winning for the team based upon the current situation and its players.">Win/Loss Probability</div> <i class="fa fa-facebook-square social_widgetShareIcon" aria-hidden="true"></i> <i class="fa fa-twitter-square social_widgetShareIcon" aria-hidden="true"></i> </div> <div class="two-teams"><p class="legent_li lengent_team1">team1 : {{wlpT1Score}}%</p><p class="legent_li lengent_team2">team2 : {{wlpT2Score}}%</p></div> </div> </div> <div class="tab_container"> <div id="winloss_prb" class="widget_items "></div> </div> <div id="wlpshare" class="inactive" style="float: left;width: 100%;"> <div class="matchsumInfo">{{matchSummary.MatchName}} - {{matchSummary.GroundName}}, {{matchSummary.MatchDate}}</div> <div class="matchsum"></div> <h1 class="widgetTitle">Win/Loss Probability</h1> <div class="two-teams"><p class="legent_li lengent_team1">team1 : {{wlpT1Score}}%</p><p class="legent_li lengent_team2">team2 : {{wlpT2Score}}%</p></div> <img class="winloss" src= "" /> </div> </div> <div class="widget momentum_widget " id="widget_momentum" ng-show="showmomentumWidget"> <div class="momntShare inactive"> <div class="matchsumInfo">{{matchSummary.MatchName}} - {{matchSummary.GroundName}}, {{matchSummary.MatchDate}}</div> <div class="matchsum"></div> </div> <h1 class="widgetTitle">Momentum</h1> <div class="wlpDetails"> <div class="wlpTeam wlpTeam1">{{mmT1}} : {{mT1Score}}%</div> <div class="wlpTeam wlpTeam2">{{mmT2}} : {{mT2Score}}%</div> <i class="fa fa-facebook-square social_widgetShareIcon" aria-hidden="true"></i> <i class="fa fa-twitter-square social_widgetShareIcon" aria-hidden="true"></i> <!-- <div class="potentialTeamScore">Score : {{wlpTeamCurrentScore}}/{{wlpTeamCurrentWicket}}</div> --> </div> <div class="widget_header momHead"> <ul class="tabBlock"> <li class="tabItem momtabOne inn1" data-inn="1" ng-click="bindmomentum(analyticsMatchId,1,\'\')" title="Tracks the shift in momentum for each team in Innings 1 after every over with the combined total momentum being 100">First Innings</li> <li class="tabItem inn2 momtabTwo" data-inn="2" ng-if="momentuminn2" ng-click="bindmomentum(analyticsMatchId,2,\'\')" title="Tracks the shift in momentum for each team in Innings 2 after every over with the combined total momentum being 100">Second Innings</li> </ul> </div> <div class="tab_container fl wl" id="momCanvas"> </div> </div> </div><!--End of Analytics--><!-- Player KPI--><div id="playerKPI" class="mcTabContent"> <span class="kpiPrintLink" onclick="document.title = \'Match KPIs\';">Print KPI </span> <span class="smLogo"> <img src="images/SM_logo.png" /> </span> <div class="tab_container w1 fl" > <div class="battingKPIwrap" > <h1 class="widgetTitle">BATTING KPI</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th>1ST INNINGS</th> <th>2ND INNINGS</th> </tr> </thead> <tbody> <tr ng-repeat="list in kpiFinal"> <td ng-bind="list.title"></td> <td ng-bind="list.data1"></td> <td ng-bind="list.data2"></td> </tr> </tbody> </table> </div> <div class="battingkeyNoteswrap" > <h1 class="widgetTitle">KEY BATTING NOTES</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th>1ST INNINGS</th> <th>2ND INNINGS</th> </tr> </thead> <tbody> <tr ng-repeat="list in keyNotesFinal"> <td ng-bind="list.title"></td> <td ng-bind="list.data1"></td> <td ng-bind="list.data2"></td> </tr> </tbody> </table> </div> <div class="bowlingKPIwrap" > <h1 class="widgetTitle">BOWLING KPI</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th>1ST INNINGS</th> <th>2ND INNINGS</th> </tr> </thead> <tbody> <tr ng-repeat="list in BowkpiFinal"> <td ng-bind="list.title"></td> <td ng-bind="list.data1"></td> <td ng-bind="list.data2"></td> </tr> </tbody> </table> </div> <div class="bowlingkeyNoteswrap" > <h1 class="widgetTitle">KEY BOWLING NOTES</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th>1ST INNINGS</th> <th>2ND INNINGS</th> </tr> </thead> <tbody> <tr ng-repeat="list in BowkeyNotesFinal"> <td ng-bind="list.title"></td> <td ng-bind="list.data1"></td> <td ng-bind="list.data2"></td> </tr> </tbody> </table> </div> <div class="battingComfortWrap" > <h1 class="widgetTitle">BATTING COMFORT LEVELS</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th colspan="2" class="tc">1ST INNINGS ({{kpiFinal[0]["data1"]}})</th> <th colspan="2" class="tc">2ND INNINGS ({{kpiFinal[0]["data2"]}})</th> </tr> <tr> <th></th> <th class="tc">PACERS</th> <th class="tc">SPINNERS</th> <th class="tc">PACERS</th> <th class="tc">SPINNERS</th> </tr> </thead> <tbody> <tr ng-repeat="list in batComfortlevel"> <td ng-bind="list.title"></td> <td ng-bind="list.data1" class="tc"></td> <td ng-bind="list.data2" class="tc"></td> <td ng-bind="list.data3" class="tc"></td> <td ng-bind="list.data4" class="tc"></td> </tr> </tbody> </table> </div> <div class="dismissalWrap" > <h1 class="widgetTitle">DISMISSAL SUMMARY</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th></th> <th>1ST INNINGS ({{kpiFinal[0]["data1"]}})</th> <th>2ND INNINGS ({{kpiFinal[0]["data2"]}})</th> </tr> </thead> <tbody> <tr ng-repeat="list in DismissalSummaryinnings1"> <td ng-bind="list.WicketType"></td> <td ng-bind="list.Innings1"></td> <td ng-bind="list.Innings2"></td> </tr> </tbody> </table> </div> <div class="indivBattingKPIWrap" > <h1 class="widgetTitle">INDIVIDUAL BATTING KPIS</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th colspan="12" class="tc">1ST INNINGS ({{kpiFinal[0]["data1"]}})</th> </tr> <tr> <th class="">PLAYER NAME</th> <th class="tc">RUNS</th> <th class="tc">BALLS</th> <th class="tc">DOTBALLS</th> <th class="tc">DB%</th> <th class="tc">DB FREQUENCY</th> <th class="tc">BDRY 4S</th> <th class="tc">BDRY 6S</th> <th class="tc">BDRY%</th> <th class="tc">BDRY FREQUENCY</th> <th class="tc">S/R</th> </tr> </thead> <tbody> <tr ng-repeat="list in IndividualbattingInn1"> <td ng-bind="list.PlayerName"></td> <td ng-bind="list.Runs"></td> <td ng-bind="list.balls"></td> <td ng-bind="list.Dotballs"></td> <td ng-bind="list.DotBallPercentage"></td> <td ng-bind="list.DotBallFrequency"></td> <td ng-bind="list.Fours"></td> <td ng-bind="list.Sixes"></td> <td ng-bind="list.BoundaryPercentage"></td> <td ng-bind="list.BoundaryFrequency"></td> <td ng-bind="list.StrikeRate"></td> </tr> </tbody> </table> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th class="tc" colspan="12" >2ND INNINGS ({{kpiFinal[0]["data2"]}})</th> </tr> <tr> <th class="">PLAYER NAME</th> <th class="tc">RUNS</th> <th class="tc">BALLS</th> <th class="tc">DOTBALLS</th> <th class="tc">DB%</th> <th class="tc">DB FREQUENCY</th> <th class="tc">BDRY 4S</th> <th class="tc">BDRY 6S</th> <th class="tc">BDRY%</th> <th class="tc">BDRY FREQUENCY</th> <th class="tc">S/R</th> </tr> </thead> <tbody> <tr ng-repeat="list in IndividualbattingInn2"> <td ng-bind="list.PlayerName"></td> <td ng-bind="list.Runs"></td> <td ng-bind="list.balls"></td> <td ng-bind="list.Dotballs"></td> <td ng-bind="list.DotBallPercentage"></td> <td ng-bind="list.DotBallFrequency"></td> <td ng-bind="list.Fours"></td> <td ng-bind="list.Sixes"></td> <td ng-bind="list.BoundaryPercentage"></td> <td ng-bind="list.BoundaryFrequency"></td> <td ng-bind="list.StrikeRate"></td> </tr> </tbody> </table> </div> <div class="indivBowlingKPIWrap"> <h1 class="widgetTitle">INDIVIDUAL BOWLING KPIS</h1> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th colspan="15" class="tc">1ST INNINGS ({{kpiFinal[0]["data2"]}})</th> </tr> <tr> <th class="">PLAYER NAME</th> <th class="tc">OVERS</th> <th class="tc">RUNS</th> <th class="tc">WICKETS</th> <th class="tc">ECON</th> <th class="tc">DOTBALLS</th> <th class="tc">DB%</th> <th class="tc">DB FREQUENCY</th> <th class="tc">BDRY 4S</th> <th class="tc">BDRY 6S</th> <th class="tc">BDRY%</th> <th class="tc">BDRY FREQUENCY</th> <th class="tc">S/R</th> <th class="tc">WIDES</th> <th class="tc">NOBALLS</th> </tr> </thead> <tbody> <tr ng-repeat="list in IndividualbowlingInn1"> <td ng-bind="list.PlayerName"></td> <td ng-bind="list.Overs"></td> <td ng-bind="list.Runs"></td> <td ng-bind="list.Wickets"></td> <td ng-bind="list.EconomyRate"></td> <td ng-bind="list.Dotballs"></td> <td ng-bind="list.DotBallPercentage"></td> <td ng-bind="list.DotBallFrequency"></td> <td ng-bind="list.Fours"></td> <td ng-bind="list.Sixes"></td> <td ng-bind="list.BoundaryPercentage"></td> <td ng-bind="list.BoundaryFrequency"></td> <td ng-bind="list.StrikeRate"></td> <td ng-bind="list.Wides"></td> <td ng-bind="list.Noballs"></td> </tr> </tbody> </table> <table class="batKPITable" class="tableDefaultSmipl nicescroll_content" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th colspan="15" class="tc">2ND INNINGS ({{kpiFinal[0]["data1"]}})</th> </tr> <tr> <th class="">PLAYER NAME</th> <th class="tc">OVERS</th> <th class="tc">RUNS</th> <th class="tc">WICKETS</th> <th class="tc">ECON</th> <th class="tc">DOTBALLS</th> <th class="tc">DB%</th> <th class="tc">DB FREQUENCY</th> <th class="tc">BDRY 4S</th> <th class="tc">BDRY 6S</th> <th class="tc">BDRY%</th> <th class="tc">BDRY FREQUENCY</th> <th class="tc">S/R</th> <th class="tc">WIDES</th> <th class="tc">NOBALLS</th> </tr> </thead> <tbody> <tr ng-repeat="list in IndividualbowlingInn2"> <td ng-bind="list.PlayerName"></td> <td ng-bind="list.Overs"></td> <td ng-bind="list.Runs"></td> <td ng-bind="list.Wickets"></td> <td ng-bind="list.EconomyRate"></td> <td ng-bind="list.Dotballs"></td> <td ng-bind="list.DotBallPercentage"></td> <td ng-bind="list.DotBallFrequency"></td> <td ng-bind="list.Fours"></td> <td ng-bind="list.Sixes"></td> <td ng-bind="list.BoundaryPercentage"></td> <td ng-bind="list.BoundaryFrequency"></td> <td ng-bind="list.StrikeRate"></td> <td ng-bind="list.Wides"></td> <td ng-bind="list.Noballs"></td> </tr> </tbody> </table> </div> </div> </div><!-- end of player kpi --><!-- News Widget--><div id="newsPage" class="mcTabContent" ng-if="news_menu"><div ng-controller="widgetCtrl"><div class="mediaContainer" menuId="3" menuName="news" menuGrp="news" mediaWidget widgetType="matchspecific"></div> <div class="matchNavContent active newsDetailBlock" ng-show="viewNewsDetailBlock"><div class="mcContainer"> <div class="matchesByType"> <div class="closeNewsDetail backTo floatRight" ng-click="closeNewsDetail()">Back</div> <header class="newArticle-header"> <h2 ng-bind="mediaDetails.Title"></h2> <p class="secTag tagColor-one" ng-if="(mediaDetails.Category != undefined && mediaDetails.Category != \'\' && mediaDetails.Category != 0)">{{getCategoryName(mediaDetails.Category)}}</p> <p class="postDate">{{mediaDetails.date}}</p> <!-- <p class="postShare">Share</p> --> </header> <div class="articleContent"> <img class="articleImg" ng-if="mediaDetails.Image != undefined && mediaDetails.Image != \'\'" ng-src="{{mediaDetails.Image}}" alt=""/> <img class="articleImg" ng-if="(mediaDetails.Image == undefined || mediaDetails.Image == \'\') && (mediaDetails.MediumThumbImage != undefined && mediaDetails.MediumThumbImage != \'\')" ng-src="{{mediaDetails.MediumThumbImage}}" alt=""/> <p ng-bind-html="mediaDetails.Description | unsafe"></p> </div> </div></div></div> </div></div><!-- End of News Widget --><!-- Photos Widget--><div id="photostreamPage" class="mcTabContent" ng-if="photostream_menu"><div ng-controller="widgetCtrl"><div class="mediaContainer" menuId="2" menuName="photos" menuGrp="photos" mediaWidget></div><div class="matchNavContent active photosDetailBlock" ng-show="viewPhotosDetailBlock"><div class="mcContainer"> <div class="matchesByType"> <div class="closeNewsDetail backTo floatRight" ng-click="closeNewsDetail()">Back</div> <section id="photoGrid-SM"><div class="col s12 m12 l12 breadcrumbSM"><p class="thumbDec">{{mediaDetails.Title}}<span>{{mediaDetails.date}}</span></p><p class="marker markerPhoto tagColor-three"><i>{{mediaDetails.Image.length}}</i></p></div> <div class="col s12 m4 l3 photoGrid-thumb" ng-repeat="item in mediaDetails.Image"> <figure class="thumb-container"> <!-- <span class="new badge red" data-badge-caption="Photo">12</span> --> <picture> <img ng-if="(item.tmedImg != undefined && item.tmedImg != \'\')" ng-src="{{item.tmedImg}}" alt="" class="thumb-image" onerror="this.src =basePath+\'images/photodefault.jpg\';"/> <img ng-if="(item.tmedImg == undefined || item.tmedImg == \'\') && (item.image != undefined && item.image != \'\')" ng-src="{{item.image}}" alt="" class="thumb-image" onerror="this.src =basePath+\'images/photodefault.jpg\';"/> <img ng-if="(item.tmedImg == undefined || item.tmedImg == \'\') && (item.image == undefined || item.image == \'\')" src="images/photodefault.jpg" alt="" class="thumb-image" /> </picture> <figcaption class="thumb-caption anim-transition"> <p class="capTitle marginB10" ng-bind="item.caption"></p> <!-- <span class="postDate">{{mediaDetails.date}}</span> --> </figcaption> <ul class="otherLinks"> <li class="newsView-icon"><a ng-href="{{item.image}}" data-fancybox="images">view</a></li> </ul> </figure> </div><div class="col s12 m12 l12 separator"></div></section> </div></div></div> </div></div><!-- End of Photos Widget --><!--Match Videos Widget--><div id="videostreamPage" class="mcTabContent" ng-if="videostream_menu"><div ng-controller="widgetCtrl"><div class="mediaContainer" menuId="1" menuName="videos" menuGrp="videos" mediaWidget></div><div class="matchNavContent active videosDetailBlock" ng-show="viewVideoDetailBlock"><div class="mcContainer"> <div class="matchesByType"> <div class="closeNewsDetail backTo floatRight" ng-click="closeNewsDetail()">Back</div> <div id="video-wrapper"> <div class="col s12 m12 l8 no-padding floatRight"> <div class="video-container"> <!-- <iframe class="video-stream" width="" height="" src="https://www.youtube.com/embed/C6bs0h_Cpfs?autoplay=1" frameborder="0" allowfullscreen></iframe> --> <video id="my-video" class="video-stream" controls controlsList="nodownload" preload="auto" width="640" height="264" data-setup="{}"> <source src="" type=\'video/mp4\'> </video> </div> </div> <div class="col s12 m12 l4 no-margin"> <div class="breadcrumbSM"> <p class="thumbDec">{{mediaDetails.Title}} <span>{{mediaDetails.date}}</span></p> </div> </div> </div> </div></div></div> </div></div><!-- End of Match Videos Widget --><!--video stream widget --><div class="liveStreamingBlock mcTabContent" ng-show="matchLiveStream && !hideLiveStream" id="liveStreamingBlock" > <div class="mcXL-12 mcLA-12 mcMED-12 mcSML-12 mcColumn noPadding liveStreamPlayerWrap"> <div id="liveStreamPlayer"> </div> </div> </div><!-- End of video stream widget --><!--Videoplayer Wrapper--><div class="cd-popup" ng-class="{inactive : videoscorecard == false}"> <div class="cd-popup-container" ng-class="{downloadEnabled : downLoadVideo == 1 || downLoadVideo == \'1\'}"> <div id="videoWrap"> <div class="mcXL-12 mcLA-12 mcMED-12 mcSML-12 mcColumn"> <marquee class="userInfoTextdemo" style="display:none;">Note: The videos are used for demo of technology to internal group and is not for any commercial use.</marquee> <input type="hidden" id="playerId" value=""/> <input type="hidden" id="playerSearch" value="" /> <div class="mediaContainer"> <video width="100%" height="100%" id="videoplayer" controls="controls" preload="none"> <source type="video/mp4" src="" /> </video> <div class="downloadPopUpWrap"> <div class="downloadPopUpInnrWrap"> <a class="downloadClose">x</a> <div class="downloadContent">Download Option </div> <div class="downloadFile"> <div class="downloadOption"> <a ng-if="downloadfromURl!= \'\'" href="" class="downloadFileIndvWrap"><span class="downloadFileIndv" title="Download Current Video">Download current video</span></a> </div> <div class="downloadFileAll" title="Download Zip File"> Download as zip</div> </div> </div> </div> </div> <div class="playlistWrap inactive"> <ul class="mejs-list"> <li ng-repeat="(key,vid) in playLists | orderBy:[\'OverNo\',\'BallName\']" data-value="{{vid.VideoFile}}" id="{{vid.BallID}}" title="{{vid.TeamName}} - {{vid.CommentOver}} - {{vid.RunsText}}" ng-click="playIndvBall(vid.BallID)">{{vid.BallName}} <span class="runIndication {{vid.RunsText}}" ng-if="vid.IsWicket == 0">{{vid.BallRuns}}</span> <span class="runIndication" ng-if="vid.IsWicket == 1">W</span> </li> </ul> <span class="prevBall ballslide"></span> <span class="nextBall ballslide"></span> </div> <div class="playerInnerWrap downloadWarp" ng-show="downloadfromURl != undefined && downloadfromURl != \'\'"> <a><span class="downloadbtn download" title="Click here to download entire playlist"> <span class="videoDownloadLink"></span> </span></a> </div> <div class="playerInnerWrap listWarp"> <a><span class="downloadbtn"> <span class="videoPlaylistLink"></span> </span></a> </div> <div class="playerInnerWrap sliderWrap"> <div class="sliderSpeedControl"></div> <div id="slider"></div> <div class="sliderMarkersWrap"> <span class="sliderMaxVal">2</span> <span class="sliderDefVal sliderRefresh" title="Refresh"></span> <span class="sliderMinVal">0.25</span> </div> <div class="sliderVal"> <div id="value"></div> <input type="hidden" id="videoplaybackRateValue" /> <span class="sliderRefresh"></span> </div> </div> <div class="playerInnerWrap videoPrevNext"> <span class="customIcon prevframe customIconUnits" title="Previous Frame"> <span class="videoFrameBackIcon iconsHld"></span> </span> <span class="previousBall customIconUnits" title="Previous" ng-click="playPrevVideo()"> <span class="videoPrevIcon iconsHld"></span> </span> <span class="pause customPlayPause customIconUnits" title="Pause"> <span class="videoPauseIcon iconsHld"></span> </span> <span class="customPlay customIconUnits" title="Play"> <span class="videoPlayIcon iconsHld"></span> </span> <span class="nextBall mejs-next customIconUnits" title="Next" ng-click="playNextVideo()"> <span class="videoNextIcon iconsHld"></span> </span> <span class="customIcon nextframe customIconUnits" title="Next Frame"> <span class="videoFrameForwardIcon iconsHld"></span> </span> </div> <div id="canvasDv" class="canvascontainer" style="display:none;"> <canvas width="500" height="400" id="canvasimage" class="canvascontainer"></canvas> <canvas width="500" height="400" id="overlayCanvas" class="canvascontainer"></canvas> <canvas width="500" height="400" id="drawingCanvas" class="canvascontainer"></canvas> <canvas width="500" height="400" id="bufferCanvas" class="canvascontainer"></canvas> </div> <div class="playerInnerWrap mcWrap"> <span class="videoMCIcon"></span> </div> <div class="mcDetails " ng-class="{singleDay : matchSummary.CurrentInnings<=2}"> <div class="mcClose"> </div> <div class="mcTeamDetails"> <div class="scoreWrap" ng-class="{active : currentInnViewNo == 1 || (currentInnViewNo == 3 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsFirstBattingID) || (currentInnViewNo == 4 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsSecondBattingID)}" ng-click="mcVideoOverlayTeamChange(matchSummary,1)"> <div class="teamName" ng-bind="matchSummary.FirstBattingTeam"></div> <div class="score"> <span ng-bind="matchSummary[\'1Summary\']"></span> <br/> <span ng-if="matchSummary.CurrentInnings>2 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsFirstBattingID && superOverSummary==\'\'">& {{matchSummary[\'3Summary\']}}</span> <span ng-if="matchSummary.CurrentInnings>2 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsSecondBattingID && superOverSummary==\'\'">& {{matchSummary[\'4Summary\']}}</span> <span ng-if="matchSummary.FirstBattingTeamID == superOverSummary.FirstBattingTeamID && superOverSummary!=\'\'">& {{superOverSummary[\'1Summary\']}}</span> <span ng-if="matchSummary.FirstBattingTeamID == superOverSummary.SecondBattingTeamID && superOverSummary!=\'\'">& {{superOverSummary[\'2Summary\']}}</span> </div> </div> <div class="scoreWrap" ng-class="{active : currentInnViewNo == 2 || (currentInnViewNo == 4 && matchSummary.SecondBattingTeamID == matchSummary.SecondInningsSecondBattingID) || (currentInnViewNo == 3 && matchSummary.SecondBattingTeamID == matchSummary.SecondInningsFirstBattingID)}" ng-click="mcVideoOverlayTeamChange(matchSummary,2)"> <div class="teamName" ng-bind="matchSummary.SecondBattingTeam"></div> <div class="score"> <span ng-bind="matchSummary[\'2Summary\']"></span> <br/> <span ng-if="matchSummary.CurrentInnings>2 && matchSummary.SecondBattingTeamID == matchSummary.SecondInningsFirstBattingID && superOverSummary==\'\'">& {{matchSummary[\'3Summary\']}}</span> <span ng-if="matchSummary.CurrentInnings>2 && matchSummary.SecondBattingTeamID == matchSummary.SecondInningsSecondBattingID && superOverSummary==\'\'">& {{matchSummary[\'4Summary\']}}</span> <span ng-if="matchSummary.SecondBattingTeamID == superOverSummary.FirstBattingTeamID && superOverSummary!=\'\'">& {{superOverSummary[\'1Summary\']}}</span> <span ng-if="matchSummary.SecondBattingTeamID == superOverSummary.SecondBattingTeamID && superOverSummary!=\'\'">& {{superOverSummary[\'2Summary\']}}</span> </div> </div> <div class="mcHeaderWrap">Match Centre</div> </div> <div class="mcInnDetails"> <div class="mcInnTabs"> <div class="mcInnTabsItems" ng-if="currentTeamInn1ID != undefined && currentTeamInn1ID != \'\'" ng-class="{active : currentInnViewNo == currentTeamInn1ID}" ng-click="mcVideoOverlayTeamChange(matchSummary,currentTeamInn1ID)" > <div ng-if="superOverSummary==\'\'"> {{currentTeamView}} 1st Innings </div> <div ng-if="superOverSummary!=\'\'"> {{currentTeamView}} Innings </div> </div> <div class="mcInnTabsItems" ng-if="currentTeamInn2ID != undefined && currentTeamInn2ID != \'\'" ng-class="{active : currentInnViewNo == currentTeamInn2ID}" ng-click="mcVideoOverlayTeamChange(matchSummary,currentTeamInn2ID)"> <div ng-if="superOverSummary==\'\'"> {{currentTeamView}} 2nd Innings </div> <div ng-if="superOverSummary!=\'\'"> {{currentTeamView}} Super Over Innings </div> </div> </div> <div class="mcInnScorecard"> <div class="mcProficiency"> <span class="batMc"> <span class="battingCardIcon"></span> </span> <span class="bowlMc"> <span class="bowlingCardIcon"></span> </span> </div> <div class="batTableWrap"> <table class="tableDetail"> <thead> <tr> <th class="fl">Batsman</th> <th class="tc vclickable" ng-click="playOverAllVideo(\'runs\')">R(B)</th> <th class="tc vclickable" ng-click="playOverAllVideo(\'fours\')">4S</th> <th class="tc vclickable" ng-click="playOverAllVideo(\'sixes\')">6S</th> </tr> </thead> <tbody> <tr ng-repeat="battingCardResult in mcVOverlaybattingCard | filter:notEmptyOrNull"> <td> <span class="batPlayerName vclickable" ng-click="playVideo(battingCardResult.PlayerID,\'all\')">{{battingCardResult.PlayerName}}</span> <span class="bowlPlayerName vclickable" ng-class="{pvclickable : checkVideoclickables(\'wicket\')}" ng-click="playVideo(battingCardResult.PlayerID,\'wicket\')">{{battingCardResult.OutDesc}} </span> </td> <td class="tc vclickable" ng-click="playVideo(battingCardResult.PlayerID,\'runs\')"><i class="ng-binding">{{battingCardResult.Runs}}</i>({{battingCardResult.Balls}})</td> <td class="tc vclickable" ng-class="{pvclickable : checkVideoclickables(\'four\')}" ng-click="playVideo(battingCardResult.PlayerID,\'four\')">{{battingCardResult.Fours}}</td> <td class="tc vclickable" ng-class="{pvclickable : checkVideoclickables(\'six\')}" ng-click="playVideo(battingCardResult.PlayerID,\'six\')">{{battingCardResult.Sixes}}</td> </tr> </tbody> </table> </div> <div class="bowlTableWrap"> <table class="tableDetail"> <thead> <tr> <th class="tl">Bowler</th> <th class="vclickable" ng-click="playOverAllVideo(\'Overs\')">O</th> <th class="vclickable" ng-click="playOverAllVideo(\'runs\')">R</th> <th class="vclickable" ng-click="playOverAllVideo(\'wicketstaken\')">WKTS</th> </tr> </thead> <tbody> <tr ng-repeat="bowlingCardResult in mcVOverlaybowlingCard"> <td class="tl vclickable" ng-click="playVideo(bowlingCardResult.PlayerID,\'bowlerall\')" ng-bind="bowlingCardResult.PlayerName"></td> <td class="vclickable" ng-click="playVideo(bowlingCardResult.PlayerID,\'overs\')" ng-bind="bowlingCardResult.Overs"></td> <td class="vclickable" ng-click="playVideo(bowlingCardResult.PlayerID,\'runsconceded\')" ng-bind="bowlingCardResult.Runs"></td> <td class="vclickable" ng-class="{pvclickable : checkVideoclickables(\'wicket\')}" ng-click="playVideo(bowlingCardResult.PlayerID,\'wicketstaken\')" ng-bind="bowlingCardResult.Wickets"></td> </tr> </tbody> </table> </div> </div> </div> </div> </div> <span class="shareIcon fb" title="Share on Facebook"></span> <span class="shareIcon twitter" title="Share on twitter"></span> <a class="cd-popup-close" ng-click="closeMCOverlay()"></a> </div> <!-- video Wrap --> </div> <!-- cd-popup-container --> </div><!--END Videoplayer--> </div><!-- END #scorecardWrapper --></div><!-- END .mcRow --></div><!-- Scorecard printblock --><div class="scorecardPrintBlk"> <div id="contentDetails" class="mcXL-12 mcLA-12 mcMED-12 mcSML-12 mcColumn no-padding"> <div id="mcDetails" class="mcXL-12 mcLA-12 mcMED-12 mcSML-12 mcColumn widgetSMIPL"> <div class="tourName" ng-bind="selectedCompetition.CompetitionName"></div> <div class="matchSummaryDetails"><div class="matchInfoDataWrap fl mcGrid_8"><div ng-if="matchSummary.MatchName!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">Match Name</span> <span class="floatLeft mcGrid_9">{{matchSummary.MatchName}}</span></div><div ng-if="matchSummary.GroundName!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">Venue</span><span class="floatLeft mcGrid_9">{{matchSummary.GroundName}}</span></div> <div ng-if="matchSummary.MatchDate!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">Date</span><span class="floatLeft mcGrid_9">{{matchSummary.MatchDate}}</span></div> <div ng-if="matchSummary.TossDetails!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">Toss Won by</span><span class="floatLeft mcGrid_9">{{matchSummary.TossDetails}}</span></div> <div class="matchResult" ng-if="matchSummary.Comments!=\'\'"><span class="floatLeft mcGrid_3">Match Result </span><span class="floatLeft mcGrid_9">{{matchSummary.Comments}}</span></div> <div class="matchResult" ng-if="matchSummary.Team1Points!=undefined && matchSummary.Team1Points!=\'\'"><span class="floatLeft mcGrid_3">Match Points: </span><span class="floatLeft mcGrid_9">{{matchSummary.FirstBattingTeam}} - {{matchSummary.Team1Points}} , {{matchSummary.SecondBattingTeam}} - {{matchSummary.Team2Points}}</span></div></div> <div class="matchInfoDataWrap fl mcGrid_4"> <div ng-if="matchSummary.Umpire1Name!=\'\' || matchSummary.Umpire2Name!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">Umpires</span> <span class="floatLeft mcGrid_9"><span ng-if="matchSummary.Umpire1Name!=\'\'">{{matchSummary.Umpire1Name}}</span> <span ng-if="matchSummary.Umpire2Name!=\'\'"> & {{matchSummary.Umpire2Name}}</span></span> </div> <div ng-if="matchSummary.Umpire3Name!=\'\'" class="marginB5"><span class="floatLeft mcGrid_3">3<sup>rd</sup> Umpire</span> <span class="floatLeft mcGrid_9">{{matchSummary.Umpire3Name}}</span> </div> <div ng-if="(matchSummary.Referee!=\'\') && clientId == \'tnca\'" class="marginB5"><span class="floatLeft mcGrid_3">Referee</span> <span class="floatLeft mcGrid_9"><span>{{matchSummary.Referee}}</span> </span> </div> <div ng-if="(matchSummary.Scorer1Name!=\'\' || matchSummary.Scorer2Name!=\'\') && clientId == \'tnca\'" class="marginB5"><span class="floatLeft mcGrid_3">Scorers</span> <span class="floatLeft mcGrid_9"><span ng-if="matchSummary.Scorer1Name!=\'\'">{{matchSummary.Scorer1Name}}</span> <span ng-if="matchSummary.Scorer2Name!=\'\'"> & {{matchSummary.Scorer2Name}}</span></span> </div> </div></div> </div> <div id="fullScorePage" class="current"> <div class="inningswiseScoreCard" ng-repeat="(key,list) in printScoreData"> <div class="inningswiseScoreCardWrap"> <div class="watermark"> <img ng-src="{{basepath}}mc/images/logo-watermark.png" /> </div> <div class="inningsName"> <div>{{matchsummaryPrint[key].teamName}}- Innings {{list.BattingCard[0].InningsNo}}</div> </div> <div class="scoreData marginT10"><span>{{matchsummaryPrint[key].summary}},RR {{matchsummaryPrint[key].RR}}</span></div> <div class="battingCardSmipl"> <div class="mcRowHead"> <div class="mcGrid_7">Batsmen</div> <div class="mcGrid_5 alignC"> <div class="mcGrid_2">R(B)</div> <div class="mcGrid_2">D</div> <div class="mcGrid_2">1\'s</div> <div class="mcGrid_2">2\'s</div> <div class="mcGrid_2">4\'s</div> <div class="mcGrid_1">6\'s</div> </div> </div> <div class="mcRowData playerWagonBatting" ng-repeat="(batKey,battingCardResult) in list.BattingCard" ng-if="((battingCardResult.OutDesc == undefined || battingCardResult.OutDesc == \'\') && (superOverSummary==\'\' || key ==0 || key ==1)) || (battingCardResult.OutDesc != undefined && battingCardResult.OutDesc != \'\')"> <div class="mcGrid_7" > <span class="playerName">{{battingCardResult.PlayerName}}</span> <span class="outdesc" ng-if="battingCardResult.OutDesc != undefined && battingCardResult.OutDesc != \'\'">{{battingCardResult.OutDesc}}</span> <span class="outdesc" ng-if="(battingCardResult.OutDesc == undefined || battingCardResult.OutDesc == \'\')">DNB</span> </div> <div class="mcGrid_5 alignC" > <div class="mcGrid_2 btRuns"><i>{{battingCardResult.Runs}}</i>({{battingCardResult.Balls}})</div> <div class="mcGrid_2">{{battingCardResult.DotBalls}}</div> <div class="mcGrid_2">{{battingCardResult.Ones}}</div> <div class="mcGrid_2">{{battingCardResult.Twos}}</div> <div class="mcGrid_2">{{battingCardResult.Fours}}</div> <div class="mcGrid_1">{{battingCardResult.Sixes}}</div> </div> </div> <div class="mcRowData"> <p class="mcExtras mcGrid_6"> <span class="ng-binding">Extras {{list.Extras[0].TotalExtras}}</span> <span>( <a class="ng-binding">b {{list.Extras[0].Byes}},</a> <a class="ng-binding">lb {{list.Extras[0].LegByes}},</a> <a class="ng-binding">w {{list.Extras[0].Wides}},</a> <a class="ng-binding">nb {{list.Extras[0].NoBalls}}</a> <a class="ng-binding" ng-if="list.Extras[0].Penalty != \'\'">, P {{list.Extras[0].Penalty}}</a>)</span> </p> <p class="mcTotal mcGrid_6 alignR vclickable" ng-click=" playInnVideo(battingCard[0].InningsNo)"> <span class="ng-binding">{{list.Extras[0].FallScore}}/{{list.Extras[0].FallWickets}} ({{list.Extras[0].FallOvers}} Overs)</span> </p> </div> </div> <div class="mcFallWicket marginB10" ng-if="list.FallOfWickets.length>0 && list.FallOfWickets[0].FallWickets !=\'0\'"> <h4><i>Fall of Wickets</i></h4> <div class="mcFallWicketList"> <p ng-repeat="(key,fallwicketResult) in list.FallOfWickets"><span class="mcFallRun">{{fallwicketResult.FallWickets}} - {{fallwicketResult.FallScore}}</span>(<span class="mcFallName"><i class="playerName">{{fallwicketResult.PlayerName}}</i>, {{fallwicketResult.FallOvers}} ov</span>)<span ng-if="key!=list.FallOfWickets.length-1"> , </span> </p> </div> </div> <div class="mcNotBat marginB15" ng-if="NotBatList.length!=0 && NotBatList[0]!=\'\'"> <h4><i ng-if="IsMatchEnd == 1">DNB</i><i ng-if="IsMatchEnd == 0">Yet To Bat</i></h4> <div class="mcNotBatList"> <p ng-repeat="(key,list) in NotBatList"><span class="playerName">{{list.PlayerName}}</span><span ng-if="key!=NotBatList.length-1"> , </span> </p> </div> </div> <!-- BowlingCard --> <div class="bowlingCardSmipl"> <div class="mcRowHead"> <div class="mcGrid_5">Bowlers</div> <div class="mcGrid_7 alignC"> <div class="mcGrid_2">o</div> <div class="mcGrid_2" ng-if="matchSummary.MatchType == \'Twenty20 Match\'">D</div> <div class="mcGrid_2" ng-if="matchSummary.MatchType != \'Twenty20 Match\'">M</div> <div class="mcGrid_2">r</div> <div class="mcGrid_1">w</div> <div class="mcGrid_2">e</div> <div class="mcGrid_1">4\'s</div> <div class="mcGrid_1">6\'s</div> </div> </div> <div class="mcRowData playerWagonBowling" ng-repeat="bowlingCardResult in list.BowlingCard"> <div class="mcGrid_5"> <span class="playerName">{{bowlingCardResult.PlayerName}}</span> </div> <div class="mcGrid_7 alignC"> <div class="mcGrid_2 bwOver">{{bowlingCardResult.Overs}}</div> <div class="mcGrid_2" ng-if="matchSummary.MatchType == \'Twenty20 Match\'">{{bowlingCardResult.DotBalls}}</div> <div class="mcGrid_2" ng-if="matchSummary.MatchType != \'Twenty20 Match\'">{{bowlingCardResult.Maidens}}</div> <div class="mcGrid_2">{{bowlingCardResult.Runs}}</div> <div class="mcGrid_1">{{bowlingCardResult.Wickets}}</div> <div class="mcGrid_2">{{bowlingCardResult.Economy}}</div> <div class="mcGrid_1">{{bowlingCardResult.Fours}}</div> <div class="mcGrid_1">{{bowlingCardResult.Sixes}}</div> </div> <div class="clear"></div> </div> <!-- End BowlingCard --> </div> </div> <div style="page-break-after: always;"></div> </div> </div> <!-- End #contentDetails --> </div> </div><!-- End of Scorecard printblock--><!-- Stats Export--><div id="exportTableWrap"></div><!-- End of Stats Export--><!-- END #mcWrapper --></div>');
} ]);

