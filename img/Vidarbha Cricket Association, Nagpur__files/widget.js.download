angular.module('MyApp', []);


angular.module("MyApp").run(["$templateCache", function ($templateCache) {
    $templateCache.put('livescores', ' <div id="mcWrapper"> <div class="mcLoader loadingPage pageloader"><div class="loader__inner">Loading...</div> </div> <div class="mcRow" id="matchCenter"><!-- START Match Wise Filter Section --><div id="matchFilterWrapper" ng-show="!showscorecard" ng-class="{cSB : customSelectBoxStyle == true}"><div class="mcContainer"> <ul class="col s12 m12 l12 no-padding eventToggler hide"> <li class="active">Association</li> <li>State Match</li> </ul> <div class="seasonFilter"> <div class="col s12 m4 l4" ng-show="showSeason && seasonList != undefined && seasonList.length > 0"> <div id="seasonBox"> <select ng-show="!customSelectBoxStyle" class="mcSelectDefault seasonList" data-ng-options="seasonData.seasonName for seasonData in seasonList" data-ng-model="selectedSeason" data-comId="" data-ng-change="changeSeason()"></select><div class="customSelecBox" ng-show="customSelectBoxStyle"><div class="cSBDisplay" ng-if="selectedSeason.seasonName != undefined && selectedSeason.seasonName != \'\'" ng-click="cSBShowList($event)">{{selectedSeason.seasonName}}</div><div class="cSBDisplay" ng-if="selectedSeason.seasonName == undefined || selectedSeason.seasonName == \'\'">Season</div><div class="cSBList"><div class="cSBListItems" ng-repeat="list in seasonList" ng-click="cSBSeasonSelect($event,list)">{{list.seasonName}}</div></div></div> </div> </div> <div class="col s12 m4 l4" ng-show="showDivision"> <div id="divisionBox"> <select ng-show="!customSelectBoxStyle" class="mcSelectDefault divisionList" data-ng-options="divsnData.DivisionName for divsnData in divisionList track by divsnData.DivisionID" data-ng-model="selectedDivision" data-ng-change="changeDivision(selectedDivision.DivisionID)"> </select> <div class="customSelecBox" ng-show="customSelectBoxStyle"><div class="cSBDisplay" ng-if="selectedDivision.DivisionName != undefined && selectedDivision.DivisionName != \'\'" ng-click="cSBShowList($event)">{{selectedDivision.DivisionName}}</div><div class="cSBDisplay" ng-if="selectedDivision.DivisionName == undefined || selectedDivision.DivisionName == \'\'">Division</div><div class="cSBList"><div class="cSBListItems" ng-repeat="list in divisionList" ng-click="cSBDivisionSelect($event,list)">{{list.DivisionName}}</div></div></div> </div> </div> <div class="col s12 m4 l4" ng-show="showMatchType"> <div class="unit_filterItemBlock matchTypeFilter"> <!-- <select class="matchTypeSel" ng-change="changeMatchType()" data-ng-options="o.MatchTypeName for o in matchType" data-ng-model="selectedmatchType"></select>--> <div class="unit_filterItems" ng-click="clickMatchType($event)"> <div class="cSelect matchTypeSel" data-text="Select Match Type">Select Match Type</div> <div class="inputSearchResultWrap"> <div class="inputSearchResult"> <div class="resultItems ng-scope" ng-repeat="(key,value) in matchTypeList"> <input name="matchType" type="checkbox" class="selId fl" value="{{value.MatchTypeName}}" id="matchTypeFilter_{{value.MatchTypeID}}" data-display="{{value.MatchTypeName}}" data-value="{{value.MatchTypeName}}" ng-change="changeMatchType()" data-ng-model="selectedmatchType"> <label for="matchTypeFilter_{{value.MatchTypeID}}"> {{value.MatchTypeName}}</label> </div> </div> </div> </div> </div> </div> <div class="col s12 m4 l4" ng-show="showCompetitionList"> <div id="competitionBox"> <select ng-show="!customSelectBoxStyle" class="mcSelectDefault competitionList mcSearchCompetition" data-ng-options="compData.CompetitionName for compData in selectedComList" data-ng-model="selectedCompetition" data-comId="" data-ng-change="changeCompetition(selectedCompetition)"> </select> <div class="customSelecBox" ng-show="customSelectBoxStyle"><div class="cSBDisplay" ng-if="selectedCompetition.CompetitionName != undefined && selectedCompetition.CompetitionName != \'\'" ng-click="cSBShowList($event)">{{selectedCompetition.CompetitionName}}</div><div class="cSBDisplay" ng-if="selectedCompetition.CompetitionName == undefined || selectedCompetition.CompetitionName == \'\'">Competition</div><div class="cSBList"><div class="cSBListSearch" ng-show="selectedComList.length > 4"><input type="text" placeholder="Search.." ng-model="cSBListSearch"></div><div class="cSBListItems" ng-repeat="list in selectedComList | filter:cSBListSearch" ng-click="cSBCompSelect($event,list)">{{list.CompetitionName}}</div></div></div> </div> </div> </div> </div></div><!-- END Match Wise Filter Section --><!-- START Menu List --><div id="mcMenuWrapper" ng-show="!showscorecard"> <div class="mcContainer"> <div class="tabLinkscontainer" ng-if="callFromTemplate !=\'result\' && callFromTemplate != \'tourstats\' && callFromTemplate != \'alllivematches\'"> <ul class="mcTabs"> <li ng-show="liveTabLink && scorecardMenu" data-value="live" ng-click="changeMatchBlk(\'live\')"><span>Live</span></li> <li ng-show="fixtureTabLink && scorecardMenu" data-value="fixture" ng-click="changeMatchBlk(\'fixture\')" class="current"><span>Fixtures</span></li> <li ng-show="resultTabLink && scorecardMenu" data-value="result" ng-click="changeMatchBlk(\'result\')"><span>Results</span></li> <li ng-show="tstatsMenu || playerstatsMenu || teamstatsMenu" data-value="stats" ng-click="showStatsBlock()"><span>Stats</span></li> <li ng-show="standingsMenu && isExist(selectedCompetition.CompetitionID) < 0 && checkInActiveForSeason(selectedSeason.SeasonID) < 0" data-value="standings" ng-click="getTStats(\'standings\')"><span>Standings</span></li> <div class="sharePage hide"><span><img ng-src="{{basepath}}images/mc-share.png" alt="Share"/></span> <div class="socialShare_widget ll"><div class="dd"><a class="socialShare_widget_Items fbshare fb-share" data-val="matchschedules" alt="FB"><img ng-src="{{basepath}}images/fb.png" /></a><a class="socialShare_widget_Items twittershare tw-share" data-val="matchschedules" alt="TW"><img ng-src="{{basepath}}images/tw.png" /></a></div></div> </div> </ul> </div> </div></div><!-- END Menu List --> <div class="sharePage mcMenuWidgetShare hide"><span><img ng-src="{{basepath}}images/mc-share.png" alt="Share"/></span> <div class="socialShare_widget ll"><div class="dd"><a class="socialShare_widget_Items fbshare fb-share" data-val="matchschedules" alt="FB"><img ng-src="{{basepath}}images/fb.png" /></a><a class="socialShare_widget_Items twittershare tw-share" data-val="matchschedules" alt="TW"><img ng-src="{{basepath}}images/tw.png" /></a></div></div> </div> <!-- Fixture - Results - Live --><div class="mcContainer" ng-show="showFixture"> <div class="col s12 m12 l12"> <!-- Fixture Box --> <div class="matchSearch col s12 m12 l4" ng-show="fixtureTab && enableFixturesSearch"><input type="search" ng-model="fixturematchSearch" placeholder="Search.."/></div> <div class="matchBox fixtureStrip uniform-grid" ng-repeat="(fixtureKey,list) in fixtureList | filter:fixturematchSearch" ng-if="list.MatchStatus != \'Live\'" ng-show="fixtureTab"> <div class="col s12 m12 l3 uniform-grid__section no-padding"> <div class="matchTeams"> <div class="logo__container"><span class="tLogo"><img ng-if="isNotNull(list.HomeTeamLogo)" ng-src="{{list.HomeTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.FirstBattingTeamName}}" /><img ng-if="!isNotNull(list.HomeTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.FirstBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.HomeTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.FirstBattingTeamName}}" /></span><span class="tVs">VS</span><span class="tLogo"><img ng-if="isNotNull(list.AwayTeamLogo)" ng-src="{{list.AwayTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.SecondBattingTeamName}}" /><img ng-if="!isNotNull(list.AwayTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.SecondBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.AwayTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.SecondBattingTeamName}}" /></span> </div> </div> </div> <div class="col s12 m12 l6 uniform-grid__section no-padding"> <div class="matchInfo" ng-class="{addBorderRight : viewFixtureDetail}"> <div class="teamNames"><p ng-bind="list.FirstBattingTeamName"></p><span>VS</span><p ng-bind="list.SecondBattingTeamName"></p></div> <div class="matchDate" ng-if="!displayZoneTime">{{list.MatchDate}}, {{list.MatchTime}}</div> <div class="matchDate" ng-if="displayZoneTime">{{getDateTimeWithTimeZone(list.MatchDate,list.MatchTime)}}</div> <div class="matchDate" ng-if="displayGMTTime">, GMT: {{list.GMTMatchTime}}</div> <div class="matchVenue"><span class="matGround" ng-bind="list.GroundName"></span> <span ng-if="(list.city !=undefined && list.city != \'\') && (list.GroundName !=undefined && list.GroundName != \'\')">,&nbsp; </span> <span class="matPlace" ng-show="list.city !=undefined && list.city != \'\'">{{list.city}}</span></div> <ul class="otherMatchInfo"> <li> <span class="addtocalendar atc-style-icon atc-style-menu-wb" ng-show="list.city != undefined && list.city != \'\'"><a class="atcb-link" tabindex="1" id="atc_icon_blue1_link"><img ng-src="{{mcpath}}addtocalendar/cal-blue.png" alt="calendar"></a><var class="atc_event"><var class="atc_date_start">{{list.MatchDate}} {{list.MatchTime}}</var><var class="atc_date_end">{{list.MatchDate}} {{list.matchEndTime}}</var><var class="atc_timezone">{{list.timezone}}</var><var class="atc_title">{{list.FirstBattingTeamName}} vs {{list.SecondBattingTeamName}}</var><var class="atc_description">{{list.GroundName}}</var><var class="atc_location">{{list.city}}</var><var class="atc_organizer"></var><var class="atc_organizer_email"></var></var></span> </li><li class="mtWeather"> <span class="fixweather_{{list.FixtureID}} inactive fixweather"><img src="" width="26px"><span class="temperatureText">{{list.weatherinfo.main.temp}}</span> <span class="tempIcon"> &#x2103;</span></span> </li><li class="mtAlert hide"><span>Notification</span></li><li class="mtShare hide">Share</li> </ul> </div> </div> <div class="col s12 m12 l3 uniform-grid__section"> <div class="resultBox col s12"> <div class="matchResult alignC" ng-if="list.Comments != undefined && list.Comments != \'\'" ng-bind="list.Comments"></div> <div class="btnWrap tc"> <div class="matchCountdown mfix_{{list.FixtureID}}"><span>Starts in</span> <div class="count">countdown</div> <div class="fixtureTimerCountdown hide fix_{{list.FixtureID}}"> <span class="iconFont days fixtureTimer"> <span class="timervalue">00</span> <span class="timerLabel">days</span> </span> <span class="iconFont hrs fixtureTimer"> <span class="timervalue">00</span> <span class="timerLabel">hrs</span> </span> <span class="iconFont mins fixtureTimer"> <span class="timervalue">00</span> <span class="timerLabel">mins</span> </span> <span class="iconFont secs fixtureTimer"> <span class="timervalue">00</span> <span class="timerLabel">secs</span> </span> </div></div><a ng-if="viewFixtureDetail" ng-click="fixtureInDetail(list.MatchID,list.CompetitionID,\'fromFixturePage\')" class="btnScorecard"><span ng-bind="fullScoreCardBtnTxt"></span>MATCH CENTRE</a> </div> </div> </div> </div> <div ng-if="fixtureList.length==0" ng-show="fixtureTab"><span class="noRecord">No Fixtures Found...</span></div><div class="matchSearch col s12 m12 l4" ng-show="resultTab && enableFixturesSearch"><input type="search" ng-model="resultmatchSearch" placeholder="Search.."/></div> <!-- Result Box --><div class="matchBox resultStrip uniform-grid" ng-repeat="list in resultList | filter:resultmatchSearch" ng-show="resultTab"> <div class="col s12 m12 l3 uniform-grid__section no-padding"> <div class="matchTeams"> <div class="matchFormat" ng-bind="list.MatchOrder"></div><div class="logo__container"><span class="tLogo"><img ng-if="isNotNull(list.HomeTeamLogo)" ng-src="{{list.HomeTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.FirstBattingTeamName}}" /><img ng-if="!isNotNull(list.HomeTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.FirstBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.HomeTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.FirstBattingTeamName}}" /></span><span class="tVs">VS</span><span class="tLogo"><img ng-if="isNotNull(list.AwayTeamLogo)" ng-src="{{list.AwayTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.SecondBattingTeamName}}" /><img ng-if="!isNotNull(list.AwayTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.SecondBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.AwayTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.SecondBattingTeamName}}" /></span></div> </div> </div> <div class="col s12 m12 l6 uniform-grid__section no-padding"> <div class="matchInfo"> <div class="matchSummary" ng-if="isNotNull(list.MatchComments)">{{list.MatchComments}}</div> <div class="teamNames"><p ng-bind="list.FirstBattingTeamName"></p><span>VS</span><p ng-bind="list.SecondBattingTeamName"></p></div> <div class="matchSummary" ng-if="!isNotNull(list.MatchComments) && list.TossDetails !=\'\'">{{list.TossDetails}}</div> <div ng-if="list.CurrentInnings == undefined || list.CurrentInnings == \'\'"> <div class="innings"> <p class="teamScore"> <span class="oruns">{{list.FirstBattingSummary}}</span> </p> <p class="vs"> <span></span> </p> <p class="teamScore"> <span class="oruns">{{list.SecondBattingSummary}} </span> </p> </div></div><div ng-if="list.CurrentInnings != undefined && list.CurrentInnings != \'\' && checkMatchResult(list)"><div class="innings"><p class="teamScore" ng-class="{activeInn : list.CurrentInnings==1}"><span class="runs" ng-if="li