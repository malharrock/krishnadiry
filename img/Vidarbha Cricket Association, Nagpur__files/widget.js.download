	function jwPlayerInit(jwPlayerVideosrc){
		if (jwplayerObj && jwplayerObj != '' && jwplayerObj != null) {
		//	jwplayerObj.remove();
		}
		
		if(jwplayerObj == '' || jwplayerObj == null || jwplayerObj == undefined || !jwplayerObj){
			jwplayerObj = jwplayer("jwplayer").setup({
										autostart : true,
										playlist: [{
										  file: jwPlayerVideosrc
										}],
										ga : {}
									});
									addJwPlayerCustomButtons();
									
								  jwplayerObj.on('playlistComplete', function() {
									playnextvideo();
								  });
								  
								  jwplayerObj.on('fullscreen', function(state) {
								   console.log(state);
								   if(state.fullscreen){
									   //$(".cd-popup-container").addClass("fullview");
								   }
								  // else
									   //$(".cd-popup-container").removeClass("fullview");
								  });
								  
								jwplayerObj.on('ready', function(event){
									var playbackRateVal = $("#videoplaybackRateValue").val();
									playbackRateVal = parseFloat(playbackRateVal);
									console.log(playbackRateVal);	
									jwplayerObj.setPlaybackRate(playbackRateVal);
									
									$(".jw-icon-fullscreen").click(function(e){
										console.log("click");
										e.stopPropagation();
									});
									
									var fullScreenBtns = document.getElementsByClassName('jw-icon-fullscreen');
									for(var i in fullScreenBtns){
										var btn = fullScreenBtns[i];
										btn.onclick = function(e){
											e.preventDefault();
											e.stopPropagation();
											console.log("Full screen is blocked");
											return false;
										};
									}
								});
		}
		else{
			if(jwPlayerVideosrc != undefined && jwPlayerVideosrc != ''){
				jwplayerObj.load([{
				  file: jwPlayerVideosrc
				}]);
			}
			
		}
		
	}
	
