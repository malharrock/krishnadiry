						if(j ==0)
							tourBowlingData[i][j]['kpi']= i+1;
						else
							tourBowlingData[i][j]['kpi']=tourBowlingStats[i][bowlingStatskeyVal[j]];
					}
				}
				$scope.tbSecTitleBow="MOST DOT BALLS";
			}
			if(stType=='mdbi'){
