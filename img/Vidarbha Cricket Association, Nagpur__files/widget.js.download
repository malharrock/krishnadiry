		  	$(".cd-popup-container .playerInnerWrap").removeClass("disableBtn");	
		  }
		  else{
		  	$(".downloadPopUpWrap").addClass("active");
		  	$(".cd-popup-container .playerInnerWrap").addClass("disableBtn");
		  }

		  var currentBallVideo = $(".mejs-list li.current").attr('data-value');
		  $(".downloadFileIndvWrap").attr("href","http://54.254.233.152/download/download.aspx?url="+currentBallVideo);
		  // $(".downloadFileIndvWrap").attr("download",currentBallVideo);
	}
	
	 function goJWPlayerFullscreen() {
		// Get the element that we want to take into fullscreen mode
		var element = document.getElementById("videoWrap");

		// These function will not exist in the browsers that don't support fullscreen mode yet,
		// so we'll have to check to see if they're available before calling them.

		if (element.mozRequestFullScreen) {
		  // This is how to go into fullscren mode in Firefox
		  // Note the "moz" prefix, which is short for Mozilla.
		  element.mozRequestFullScreen();
		} else if (element.webkitRequestFullScreen) {
		  // This is how to go into fullscreen mode in Chrome and Safari
		  // Both of those browsers are based on the Webkit project, hence the same prefix.
		  element.webkitRequestFullScreen();
	   }
	   // Hooray, now we're in fullscreen mode!
	   $('.jw-icon[button=jwfullscreen]').addClass('inactive');
	   $('.jw-icon[button=jwexitfullscreen]').addClass('active');
	   $('.cd-popup-container').addClass('fullview');
		$(".mcDetails").removeClass("active");
	  }
	  
	  
	  function cancelJWPlayerFullscreen() {
		 if (document.exitFullscreen) {
			document.exitFullscreen();
		  } else if (document.mozCancelFullScreen) { /* Firefox */
			document.mozCancelFullScreen();
		  } else if (document.webkitExitFullscreen) { /* Chrome, Safari and Opera */
			document.webkitExitFullscreen();
		  } else if (document.msExitFullscreen) { /* IE/Edge */
			document.msExitFullscreen();
		  }
		  $('.cd-popup-container').removeClass('fullview');
		  $('.jw-icon[button=jwfullscreen]').removeClass('inactive');
		  $('.jw-icon[button=jwexitfullscreen]').removeClass('active');
		var windowWth = $(window).width();
		if(windowWth > 1024){
			$(".mcDetails").addClass("active");
		}
		else{
			$(".mcDetails").removeClass("active");
		}
	  }
	
	
