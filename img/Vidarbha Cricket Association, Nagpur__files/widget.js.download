-value="tmtStats">Tournament</li> <li ng-show="teamstatsMenu" ng-click="getTStats(\'teamDetailStats\')" data-value="teamStats">Team</li> <li ng-show="playerstatsMenu" ng-click="getTStats(\'teamstats\')" data-value="playerStats">Player</li> </ul> </div></div><!-- START Team stats --><div id="teamStatsWrapper" ng-show="showteamstats" ng-if="overallTeamStats!= \'\'"> <div class="statsHeader"> <div class="mcContainer"> <div class="col s12 m12 l12"><select class="mcSelectDefault teamListFilter teamstatsFilter" data-ng-options="teamData.TeamName for teamData in teamListFilter track by teamData.TeamID" data-ng-model="selectedTeamFilter" data-teamId="{{teamListFilter.teamId}}" data-ng-change="changeTeamBasicStats(selectedTeamFilter)"></select><ul class="statsList" ng-if="overallTeamStats != undefined"><li><div class="displayTable"><div class="displayTableCell"><span>Matches</span><i>{{isZero(overallTeamStats.Matches)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Won</span><i>{{isZero(overallTeamStats.Wins)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Lost</span><i>{{isZero(overallTeamStats.Loss)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>No Result</span><i>{{isZero(overallTeamStats.Aban)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Runs Scored</span><i>{{isZero(overallTeamStats.RunsScored)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Runs Conceded</span><i>{{isZero(overallTeamStats.RunsConceded)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Wickets Lost</span><i>{{isZero(overallTeamStats.WicketLost)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Wickets Taken</span><i>{{isZero(overallTeamStats.WicketsTaken)}}</i></div></div></li><li><div class="displayTable"><div class="displayTableCell"><span>Points</span><i>{{isZero(overallTeamStats.Points)}}</i></div></div></li><li ng-if="compMatchType == \'Twenty20 Match\' && overallTeamStats.Thirties != undefined"><div class="displayTable"><div class="displayTableCell"><span>30\'s</span><i>{{isZero(overallTeamStats.Thirties)}}</i></div></div></li><li ng-if="overallTeamStats.Fifties != undefined"><div class="displayTable"><div class="displayTableCell"><span>50\'s</span><i>{{isZero(overallTeamStats.Fifties)}}</i></div></div></li><li ng-if="compMatchType != \'Twenty20 Match\'"><div class="displayTable"><div class="displayTableCell"><span>100\'s</span><i>{{isZero(overallTeamStats.Centuries)}}</i></div></div></li><li ng-if="compMatchType == \'Twenty20 Match\' && overallTeamStats.Partnership30 != undefined"><div class="displayTable"><div class="displayTableCell"><span>30+ Pship\'s</span><i>{{isZero(overallTeamStats.Partnership30)}}</i></div></div></li><li ng-if="compMatchType != \'Twenty20 Match\' && overallTeamStats.Partnership50 != undefined"><div class="displayTable"><div class="displayTableCell"><span>50+ Pship\'s</span><i>{{isZero(overallTeamStats.Partnership50)}}</i></div></div></li><li ng-if="compMatchType != \'Twenty20 Match\'"><div class="displayTable"><div class="displayTableCell"><span>100+ Pship\'s</span><i>{{isZero(overallTeamStats.Partnership100)}}</i></div></div></li><li ng-if="compMatchType != undefined && compMatchType!=\'\' && compMatchType == \'Twenty20 Match\' && overallTeamStats.ThreeWickets != undefined"><div class="displayTable"><div class="displayTableCell"><span>3 Wicket Haul</span><i>{{isZero(overallTeamStats.ThreeWickets)}}</i></div></div></li><li ng-if="compMatchType != undefined && compMatchType!=\'\' && compMatchType != \'Multi Day\' && false"><div class="displayTable"><div class="displayTableCell"><span>4 Wicket Haul</span><i>{{isZero(overallTeamStats.FourWickets)}}</i></div></div></li><li ng-if="compMatchType != undefined && compMatchType!=\'\' && compMatchType != \'Twenty20 Match\' && overallTeamStats.FiveWickets != undefined"><div class="displayTable"><div class="displayTableCell"><span>5 Wicket Haul</span><i>{{isZero(overallTeamStats.FiveWickets)}}</i></div></div></li><li ng-if="compMatchType != undefined && compMatchType!=\'\' && compMatchType == \'Multi Day\' && overallTeamStats.TenWickets != undefined"><div class="displayTable"><div class="displayTableCell"><span>10 Wicket Haul</span><i>{{isZero(overallTeamStats.TenWickets)}}</i></div></div></li><li ng-if="overallTeamStats.BowlingExtras != undefined"><div class="displayTable"><div class="displayTableCell"><span>Extras</span><i>{{isZero(overallTeamStats.BowlingExtras)}}</i></div></div></li></ul></div> </div><!-- END .statsHeader --> </div><div class="statsContent"><div class="mcContainer"><div class="col s12 m12 l12"> <ul class="mcTabs roleTab teamTab"> <li class="mcTabLink current" ng-click="showTeamDetStats()" data-tab="mcTeamBattingStats"><span href="#mcTeamBattingStats">Batting Stats</span></li> <li class="mcTabLink" ng-click="showTeamDetStats()" data-tab="mcTeamBowlingStats"><span href="#mcTeamBowlingStats">Bowling Stats</span></li> </ul> <span class="statsPrintIcon" title="Print Stats" ng-show="printStats == \'true\'"></span> <span class="statsExportExcelIcon" title="Export Excel" ng-show="exportStats == \'true\'"></span> <div id="mcTeamBattingStats" class="tabTeamContent current"><table class="mcTableDefault batCardTable" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <tr> <th ng-repeat="(key,value) in teambattingStatsHeadTitle" class="" data-key="{{key}}">{{value}}</th> </tr> </tr></thead> <tbody> <tr ng-repeat="(key,list) in basicteamstats | orderBy:\'-RunsScored\'"> <td ng-repeat="value in teambattingStatskeyVal">{{list[value]}}</td> </tr> <tr ng-if="basicteamstats.length == 0"><td class="tc" colspan="13">No Data Found</td></tr></tbody> </table><!-- End #mcTeamBattingStats --> </div><div id="mcTeamBowlingStats" class="tabTeamContent"><table class="mcTableDefault bowCardTable" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th ng-repeat="(key,value) in teambowlingStatsHeadTitle" class="" data-key="{{key}}">{{value}}</th> </tr></thead> <tbody> <tr ng-repeat="(key,list) in basicteamstats | orderBy:\'-WicketsTaken\'"> <td ng-repeat="value in teambowlingStatskeyVal">{{list[value]}}</td> </tr> <tr ng-if="basicteamstats.length == 0"><td class="tc" colspan="14">No Data Found</td></tr></tbody> </table><!-- End #mcTeamBowlingStats --></div></div></div><!-- END .statsContent --></div></div><!-- END Team stats --><!-- START Player stats --><div id="playerStatsWrapper" ng-show="showplayerstats"><div class="statsHeader"><div class="mcContainer"> <div class="mcSelectBox"><div class="col s12 m6 l3"><select class="mcSelectDefault mcSearchTeam" data-ng-options="teamData.TeamName for teamData in teamList" data-ng-model="selectedTeam" data-teamId="{{teamList.teamId}}" data-ng-change="changeTeam(selectedTeam)"> </select></div><div class="col s12 m6 l3"> <p class="mcSearchResults icon-search-1"><input type="text" class="mcSearchDefault" placeholder="Type to search your player here..." ng-model="searchPlayerName.PlayerName"></p></div><!-- End .mcSelectBox --> </div> <div id="plyRotateSmipl"> <div class="mcPlyRotList"></div> <!-- END #plyRotateSmipl --> </div> <div class="errMsg"></div> <div class="col s12 m12 l5 no-padding pStatsWrap" > <div class="mcPlyStatsHeader"><div class="plyImg"><img ng-if="isNotNull(playerScoreData.profileimg)" ng-src="{{playerImgPath+playerScoreData.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" class="mcPltPic"/><img ng-if="!isNotNull(playerScoreData.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" class="mcPltPic"/></div><div class="positionDetail"><p class="mcPlyName">{{playerScoreData.PlayerName}}<span class="hide">Age - 30</span></p><table class="player-details"><tbody><tr><td>Role</td><td>{{playerScoreData.Specialization}}</td></tr><tr><td>Batting Style</td><td>{{playerScoreData.BattingType}}</td></tr><tr><td>Bowling Style</td><td>{{playerScoreData.BowlingType}}</td></tr></tbody></table><div class="mcPlyOption"><span class="batOption opActive" ng-click="changePlayAction(\'batOption\')">Batting</span><span class="bowOption" ng-click="changePlayAction(\'bowOption\')">Bowling</span></div></div> <!-- End .mcStatsHeader --> </div> </div> <div class="col s12 m12 l7 no-padding pStatsWrap"> <ul class="statsList no-margin" ng-show="mcPlayerBattingStats"><li><span>Matches</span><i>{{playerScoreData.Matches}}</i></li><li><span>Innings</span><i>{{playerScoreData.Innings}}</i></li><li><span>Runs</span><i>{{playerScoreData.RunsScored}}</i></li><li><span>Balls</span><i>{{playerScoreData.BallsFaced}}</i></li><li><span>SR</span><i>{{playerScoreData.StrikeRate}}</i></li><li><span>Average</span><i>{{playerScoreData.BattingAverage}}</i></li><li><span>fours</span><i>{{playerScoreData.Bdry4Scored}}</i></li><li><span>Sixes</span><i>{{playerScoreData.Bdry6Scored}}</i></li><li><span>50\'s</span><i>{{playerScoreData.Fifties}}</i></li><li><span>100\'s</span><i>{{playerScoreData.Hundreds}}</i></li><li><span>Bdry Freq.</span><i>{{playerScoreData.BdryFreq}}</i></li><li><span>Boundary%</span><i>{{playerScoreData.BdryPercent}}</i></li><li><span>Dot Balls</span><i>{{playerScoreData.DotBalls}}</i></li><li><span>Dot Freq.</span><i>{{playerScoreData.DotBallFrequency}}</i></li><li><span>Dot Ball %</span><i>{{playerScoreData.DBPercent}}</i></li></ul><ul class="statsList no-margin" ng-show="mcPlayerBowlingStats"><li><span>Matches</span><i>{{playerScoreData.Matches}}</i></li><li><span>Innings</span><i>{{playerScoreData.InningsBowled}}</i></li><li><span>Overs</span><i>{{playerScoreData.OversBowled}}</i></li><li><span>Runs</span><i>{{playerScoreData.TotalRunsConceeded}}</i></li><li><span>Wickets</span><i>{{playerScoreData.WicketsTaken}}</i></li><li ng-if="matchSummary.MatchType == \'Twenty20 Match\'"><span>3W</span><i>{{playerScoreData[\'3Wickets\']}}</i></li><li><span>Average</span><i>{{playerScoreData.BowlingAverage}}</i></li><li><span>Economy</span><i>{{playerScoreData.EconomyRate}}</i></li><li><span>SR</span><i>{{playerScoreData.BowlingSR}}</i></li><li><span>Maidens</span><i>{{playerScoreData.Maidens}}</i></li><li><span>Bdry Freq.</span><i>{{playerScoreData.BowlingBdryFrequency}}</i></li><li><span>Boundary%</span><i>{{playerScoreData.BowlingBdryPercentage}}</i></li><li><span>Dot Balls</span><i>{{playerScoreData.DotBallsBowled}}</i></li><li><span>Dot Freq.</span><i>{{playerScoreData.BowlingDotBallFrequency}}</i></li><li><span>Dot Ball %</span><i>{{playerScoreData.BowlingDotBallPercent}}</i></li></ul> </div></div><!-- END .statsHeader --> </div><div class="statsContent hide"><div class="mcContainer"> <div class="col s12 m6 l6 no-padding"> <!-- Boundary --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Boundary%</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC1" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC1" style="width: 75%;">&nbsp;</span></p></div></div> </div> <div class="col s12 m6 l6 no-padding"> <!-- Runs --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Runs</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC2" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC2" style="width: 75%;">&nbsp;</span></p></div></div> </div><div class="col s12 m6 l6 no-padding"> <!-- Dot Ball % --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Dot Ball %</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC3" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC3" style="width: 75%;">&nbsp;</span></p></div></div> </div><div class="col s12 m6 l6 no-padding"> <!-- Strike Rate --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Strike Rate</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC4" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC4" style="width: 75%;">&nbsp;</span></p></div></div> </div><div class="col s12 m6 l6 no-padding"> <!-- Dot Ball Frequency --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Dot Ball Frequency</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC5" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC5" style="width: 75%;">&nbsp;</span></p></div></div> </div><div class="col s12 m6 l6 no-padding"> <!-- Boundary Frequency --><div id="mcBoundaryStatsBox" class="mcStatsBox"><h4>Boundary Frequency</h4><div class="mcFirstInn"> <span class="innScore">Inn 1<i>51.10</i></span><p title="1" class="growth"><span class="growth-full-left mcBgC6" style="width: 50%;">&nbsp;</span></p></div><div class="mcSecondInn no-margin"> <span class="innScore">Inn 2<i>51.10</i></span> <p title="2" class="growth"><span class="growth-full-left mcBgC6" style="width: 75%;">&nbsp;</span></p></div></div> </div> </div> </div></div><!-- END Player stats --><!-- START Tournament stats --><div id="tournamentStatsWrapper" ><div class="tournamentStatsWrapper" ng-show="showtourstats" ng-if="tourBattingKPI != \'\'"> <div class="statsHeader"> <div class="mcContainer"> <div class="col s12 m12 l12"><ul class="statsList no-margin"><li><span>Matches</span><i>{{isZero(tourBattingKPI.Matches)}}</i></li><li ng-if="competitionType != \'Twenty20 Match\'"><span>Innings</span><i>{{isZero(tourBowlingKPI.Innings)}}</i></li><li><span>Runs</span><i>{{isZero(tourBattingKPI.TotalRuns)}}</i></li><li ng-if="tourBattingKPI.WicketsLost != undefined"><span>Wickets</span><i>{{isZero(tourBattingKPI.WicketsLost)}}</i></li><li ng-if="tourBattingKPI.WicketLost != undefined"><span>Wickets</span><i>{{isZero(tourBattingKPI.WicketLost)}}</i></li><li ng-if="tourBowlingKPI.TotalLegalBallsBowled != undefined"><span>Balls</span><i>{{isZero(tourBowlingKPI.TotalLegalBallsBowled)}}</i></li><li ng-if="tourBowlingKPI.LegalBallsBowled != undefined"><span>Balls</span><i>{{isZero(tourBowlingKPI.LegalBallsBowled)}}</i></li><li ng-if="competitionType != \'Multi Day\'"><span>Ones</span><i>{{isZero(tourBattingKPI.Ones)}}</i></li><li ng-if="competitionType != \'Multi Day\'"><span>Twos</span><i>{{isZero(tourBattingKPI.Twos)}}</i></li><li ng-if="competitionType != \'Multi Day\'"><span>Threes</span><i>{{isZero(tourBattingKPI.Threes)}}</i></li><li><span>fours</span><i>{{isZero(tourBattingKPI.Bdry4)}}</i></li><li><span>Sixes</span><i>{{isZero(tourBattingKPI.Bdry6)}}</i></li><li ng-if="competitionType == \'Twenty20 Match\' && tourBattingStatsKPI.Thirties != undefined"><span>30\'s</span><i>{{isZero(tourBattingStatsKPI.Thirties)}}</i></li><li><span>50\'s</span><i>{{isZero(tourBattingStatsKPI.HalfCenturies)}}</i></li><li ng-if="competitionType != \'Twenty20 Match\'"><span>100\'s</span><i>{{isZero(tourBattingStatsKPI.Centuries)}}</i></li><li ng-if="competitionType == \'Twenty20 Match\'"><span>30+ Partnership</span><i>{{isZero(tourBattingStatsKPI.ThirtyPartnership)}}</i></li><li><span>50+ Partnership</span><i>{{isZero(tourBattingStatsKPI.FiftyPartnership)}}</i></li><li ng-if="competitionType != \'Twenty20 Match\'"><span>100+ Partnership</span><i>{{isZero(tourBattingStatsKPI.HundredPartnership)}}</i></li><li><span>Maidens</span><i>{{isZero(tourBowlingKPI.Maidens)}}</i></li><li><span>Dot Balls</span><i>{{isZero(tourBattingKPI.Dotballs)}}</i></li><li><span>Dot Ball %</span><i>{{isZero(tourBattingKPI.DBPercent)}}</i></li><li ng-if="tourBattingKPI.DotBallFrequency != undefined"><span>DB Freq.</span><i>{{isZero(tourBattingKPI.DotBallFrequency)}}</i></li><li ng-if="tourBattingKPI.DBFrequency != undefined"><span>DB Freq.</span><i>{{isZero(tourBattingKPI.DBFrequency)}}</i></li><li><span>Bdry Freq.</span><i>{{isZero(tourBattingKPI.BdryFreq)}}</i></li><li><span>Boundary%</span><i>{{isZero(tourBattingKPI.BdryPercent)}}</i></li><li><span>Extras</span><i>{{isZero(tourBattingKPI.RunsThroughExtras)}}</i></li><li><span>Catches</span><i>{{isZero(tourBattingKPI.Catches)}}</i></li><li><span>Stumpings</span><i>{{isZero(tourBattingKPI.Stumpings)}}</i></li></ul></div> </div><!-- END .statsHeader --> </div> <!-- Top Performers --> <div id="mcBestPerformers"><div class="mcContainer"> <h4 class="mcTitle">Top Performers</h4> <div class="col s12 m6 l3" ng-if="indivPlayerTR!=undefined"> <!-- Top Run Getter --> <div id="topRunGetter"> <h5 class="mcTitle">Top Run Getter</h5> <div class="mcPerformersList"> <a class="mcTopOne"> <span class="mcPlyImg"> <img ng-if="isNotNull(indivPlayerTR.profileimg)" ng-src="{{playerImgPath+indivPlayerTR.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(indivPlayerTR.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </span><span class="mcTopOneDetail"> <span class="mcTopPlyName">{{indivPlayerTR.PlayerName}}</span><span class="mcTopScore">{{indivPlayerTR.KPIValues}}<span class="topCategory">Runs</span></span><span class="mcTopTeamName">{{indivPlayerTR.TeamName}}</span></span> </a> <div class="mcOtherTppWrap"> <div class="mcOtherTpp" ng-repeat="(key,toprungetters) in topBattingPlayerList[0][\'toprungetters\'] | orderBy:\'Rank\'" ng-if="key != 0"> <p class="plyImg"> <img ng-if="isNotNull(toprungetters.profileimg)" ng-src="{{playerImgPath+toprungetters.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(toprungetters.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </p><p class="plyName">{{toprungetters.PlayerName}}<span>{{toprungetters.TeamName}}</span></p><p class="plyStats">Runs<span>{{toprungetters.KPIValues}}</span></p> </div></div> <a href="tstats.html" class="btn hide">View More</a> </div> </div> </div> <div class="col s12 m6 l3" ng-if="indivPlayerHW!=undefined"> <!-- Leading Wicket Takers --> <div id="leadWcktTakers"> <h5 class="mcTitle">Leading Wicket Takers</h5> <div class="mcPerformersList"> <a class="mcTopOne"> <span class="mcPlyImg"> <img ng-if="isNotNull(indivPlayerHW.profileimg)" ng-src="{{playerImgPath+indivPlayerHW.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(indivPlayerHW.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </span><span class="mcTopOneDetail"> <span class="mcTopPlyName">{{indivPlayerHW.PlayerName}}</span><span class="mcTopScore">{{indivPlayerHW.KPIValues}}<span class="topCategory">Wickets</span></span><span class="mcTopTeamName">{{indivPlayerHW.TeamName}}</span></span> </a> <div class="mcOtherTppWrap"> <div class="mcOtherTpp" ng-repeat="(key,highestWicket) in topBowlingPlayerList[0][\'highestWicket\'] | orderBy:\'Rank\'" ng-if="key != 0"> <p class="plyImg"> <img ng-if="isNotNull(highestWicket.profileimg)" ng-src="{{playerImgPath+highestWicket.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(highestWicket.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </p><p class="plyName">{{highestWicket.PlayerName}}<span>{{highestWicket.TeamName}}</span></p><p class="plyStats">Wickets<span>{{highestWicket.KPIValues}}</span></p> </div></div> <a href="tstats.html" class="btn hide">View More</a> </div> </div> </div> <div class="col s12 m6 l3" ng-if="indivPlayerHSR!=undefined"> <!-- Top Run Getter --> <div id="higiestSr"> <h5 class="mcTitle">Highest SR (Min: 25 Runs)</h5> <div class="mcPerformersList"> <a href="" class="mcTopOne"> <span class="mcPlyImg"> <img ng-if="isNotNull(indivPlayerHSR.profileimg)" ng-src="{{playerImgPath+indivPlayerHSR.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(indivPlayerHSR.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </span><span class="mcTopOneDetail"> <span class="mcTopPlyName">{{indivPlayerHSR.PlayerName}}</span><span class="mcTopScore">{{indivPlayerHSR.KPIValues}}<span class="topCategory">SR</span></span><span class="mcTopTeamName">{{indivPlayerHSR.TeamName}}</span></span> </a> <div class="mcOtherTppWrap"> <div class="mcOtherTpp" ng-repeat="(key,highestSR) in topBattingPlayerList[0][\'highestSR\'] | orderBy:\'Rank\'" ng-if="key != 0"> <p class="plyImg"> <img ng-if="isNotNull(highestSR.profileimg)" ng-src="{{playerImgPath+highestSR.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(highestSR.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </p><p class="plyName">{{highestSR.PlayerName}}<span>{{highestSR.TeamName}}</span></p><p class="plyStats">SR<span>{{highestSR.KPIValues}}</span></p> </div></div> <a href="tstats.html" class="btn hide">View More</a> </div> </div> </div> <div class="col s12 m6 l3" ng-if="indivPlayerER!=undefined"> <!-- Top Run Getter --> <div id="bestEcon"> <h5 class="mcTitle">Best Economy (Min: 4 Overs)</h5> <div class="mcPerformersList"> <a class="mcTopOne"> <span class="mcPlyImg"> <img ng-if="isNotNull(indivPlayerER.profileimg)" ng-src="{{playerImgPath+indivPlayerER.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(indivPlayerER.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </span><span class="mcTopOneDetail"> <span class="mcTopPlyName">{{indivPlayerER.PlayerName}}</span><span class="mcTopScore">{{indivPlayerER.KPIValues}}<span class="topCategory">ECON</span></span><span class="mcTopTeamName">{{indivPlayerER.TeamName}}</span></span> </a> <div class="mcOtherTppWrap"> <div class="mcOtherTpp" ng-repeat="(key,economyRate) in topBowlingPlayerList[0][\'economyRate\'] | orderBy:\'Rank\'" ng-if="key != 0"> <p class="plyImg"> <img ng-if="isNotNull(economyRate.profileimg)" ng-src="{{playerImgPath+economyRate.profileimg}}" onerror="this.src = basePath+\'images/placeholder.png\';" alt="" /> <img ng-if="!isNotNull(economyRate.profileimg)" ng-src="{{basepath}}images/placeholder.png" alt="" /> </p><p class="plyName">{{economyRate.PlayerName}}<span>{{economyRate.TeamName}}</span></p><p class="plyStats">ECON<span>{{economyRate.KPIValues}}</span></p> </div></div> <a href="tstats.html" class="btn hide">View More</a> </div> </div> </div> </div></div> <div class="statsContent" ng-show="detailedTstats"><div class="mcContainer"><div class="col s12 m12 l12"> <ul class="mcTabs roleTab tourTab"> <li class="mcTabLink current" data-tab="mcTourBattingStats" ng-click="showTourDetStats(\'mcTourBattingStats\')"><span>Batting Stats</span></li> <li class="mcTabLink" data-tab="mcTourBowlingStats" ng-click="showTourDetStats(\'mcTourBowlingStats\')"><span>Bowling Stats</span></li> </ul> <span class="statsPrintIcon" title="Print Stats" ng-show="printStats == \'true\'"></span> <span class="statsExportExcelIcon" title="Export Excel" ng-show="exportStats == \'true\'"></span><div id="mcTourBattingStats" class="tabTourContent current"> <div class="otherStats"> <select class="mcSelectDefault otherStatsFilter" data-ng-options="batData.col1 for batData in battingStatsList" data-ng-model="selbattingStatsList" ng-change="tstatsBatting(selbattingStatsList.col2,selbattingStatsList.col3)"> </select> </div><div class="nicescroll_content tmtBatStatsContent js-statsTableWrap"><table class="mcTableDefault batCardTable" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th ng-repeat="(key,value) in battingStatsHeadTitle" ng-if="tourBattingData[0][key].kpi!=undefined" ng-click="changeSorting(key,\'batting\',$event)" class="" data-key="{{key}}">{{value}}</th> </tr></thead> <tbody> <tr ng-repeat="(key,list) in tourBattingData"> <td ng-repeat="value in list" ng-if="value.kpi!=undefined">{{value.kpi}}</td> </tr></tbody> </table></div><!-- End #mcTeamBattingStats --></div><div id="mcTourBowlingStats" class="tabTourContent"> <div class="otherStats"> <select class="mcSelectDefault otherStatsFilter" data-ng-options="bowData.col1 for bowData in bowlingStatsList" data-ng-model="selbowlingStatsList" ng-change="tstatsBowling(selbowlingStatsList.col2,selbowlingStatsList.col3)"> </select> </div> <div class="nicescroll_content tmtBowStatsContent js-statsTableWrap"> <table class="mcTableDefault bowCardTable" cellspacing="0" cellpadding="0" border="0"> <thead> <tr> <th ng-repeat="(key,value) in bowlingStatsHeadTitle" ng-click="changeSorting(key,\'bowling\',$event)" class="" data-key="{{key}}">{{value}}</th> </tr></thead> <tbody> <tr ng-repeat="(key,list) in tourBowlingData"> <td ng-repeat="value in list">{{value.kpi}}</td> </tr></tbody> </table> </div><!-- End #mcTeamBowlingStats --></div></div></div><!-- END .statsContent --></div></div><div ng-if="noTstats" class="noRecord">No Stats Found..</div></div><!-- END Tournament stats --> <!--- SCORECARD WRAP --><div id="scorecardWrapper" ng-show="showscorecard"> <div class="matchHead uniform-grid"> <a class="back" ng-click="backToFixtures()"> <span class="icon-angle-left"></span> <span class="logo z-depth-2"> <img ng-if="clientLogo != \'\'" ng-src="{{clientLogo}}" alt="{{clientName}}"></span> <h1 ng-bind="clientCode"></h1> </a> <div class="matchNav icon-down-open-mini1" ng-show="selectedCompetition.CompetitionName != \'All Live Matches\'"><span ng-show="showDivision && false">{{selectedDivision.DivisionName}} - </span><span ng-bind="matchSummary.MatchName"></span></div></div> <!-- Other MATCH LIST --> <div class="matchNavContent"><div class="mcContainer"> <div class="matchesByType" ng-if="resultList.length > 0"> <h5 class="header">Results</h5> <ul class="matchList"><li class="col s12 m4 l3" ng-repeat="list in resultList"> <a href="{{basepath}}{{fullScorecardBasePath}}?type=scorecard&mId={{list.MatchID}}&cId={{list.CompetitionID}}&dId={{list.DivisionID}}&sId={{selectedSeason.SeasonID}}" class="event" ng-class="{disableClick:list.FirstBattingSummary == \'\'}"> <div class="eventDetail"><span ng-if="list.MatchOrder != undefined && list.MatchOrder != \'\'">{{list.MatchOrder}} - </span>{{list.MatchDate}}</div> <div class="eventDetail"><span ng-if="list.Comments != undefined && list.Comments != \'\'">{{list.Comments}}</span></div> <div class="team winner"><span><img ng-if="isNotNull(list.HomeTeamLogo)" ng-src="{{list.HomeTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.FirstBattingTeamName}}" /><img ng-if="!isNotNull(list.HomeTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.FirstBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.HomeTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.FirstBattingTeamName}}" /></span><span>{{list.FirstBattingTeamName}} <i>{{list.FirstBattingSummary}}</i></span> </div> <div class="team no-padding"><span><img ng-if="isNotNull(list.AwayTeamLogo)" ng-src="{{list.AwayTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.SecondBattingTeamName}}" /><img ng-if="!isNotNull(list.AwayTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.SecondBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.AwayTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.SecondBattingTeamName}}" /></span><span>{{list.SecondBattingTeamName}} <i>{{list.SecondBattingSummary}}</i></span> </div> </a></li> </ul> </div> <div class="matchesByType" ng-if="fixtureList.length > 0"> <h5 class="header matFix">Upcoming Match</h5><ul class="matchList upComMatch"><li class="col s12 m4 l3" ng-repeat="(fixtureKey,list) in fixtureList" ng-click="fixtureInDetail(list.MatchID,list.CompetitionID,\'fromFixturePage\',\'fromUpcoming\')"> <a class="event"> <div class="eventDetail"><span ng-if="list.MatchOrder != undefined && list.MatchOrder != \'\'">{{list.MatchOrder}} - </span>{{list.MatchDate}}</div> <div class="team"><span><img ng-if="isNotNull(list.HomeTeamLogo)" ng-src="{{list.HomeTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.FirstBattingTeamName}}" /><img ng-if="!isNotNull(list.HomeTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.FirstBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.HomeTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.FirstBattingTeamName}}" /></span><span ng-bind="list.FirstBattingTeamName"></span> </div> <div class="team no-padding"><span><img ng-if="isNotNull(list.AwayTeamLogo)" ng-src="{{list.AwayTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{list.SecondBattingTeamName}}" /><img ng-if="!isNotNull(list.AwayTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{list.SecondBattingTeamName}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(list.AwayTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{list.SecondBattingTeamName}}" /></span><span ng-bind="list.SecondBattingTeamName"></span> </div> </a></li></ul> </div><!-- END .mcContainer --></div> <!-- END .matchNavContent --> </div><!-- Brief Score Board --><div id="briefScoreBoard"><!-- SCORE BOX --><div id="scoreBox"><div class="mcContainer"><div class="col s12 m12 l12"> <div class="col s12 m12 l12"> <div class="tournament--logo-wrap tc" ng-if="(matchSummary.CompetitionLogo != undefined && matchSummary.CompetitionLogo!=\'\')"> <div class="tournament--logo"><img ng-src="{{matchSummary.CompetitionLogo}}" /></div> </div> <div class="tournament--name" ng-if="selectedCompetition.CompetitionName != \'All Live Matches\' && (matchSummary.CompetitionName == undefined || matchSummary.CompetitionName==\'\')">{{selectedCompetition.CompetitionName}}</div> <div class="tournament--name" ng-if="(matchSummary.CompetitionName != undefined && matchSummary.CompetitionName!=\'\')">{{matchSummary.CompetitionName}}</div> <div class="matchSummary"> <div class="" ng-if="matchSummary.Comments!=\'\'" ng-bind="matchSummary.Comments"></div> <div class="" ng-if="matchSummary.IsMatchEnd != undefined && matchSummary.Comments!=undefined && matchSummary.Comments ==\'\'"> <div ng-init="getcurMatchDetFromSchdule(matchSummary.MatchID)">{{curMatchDetFromSchdule.Comments}}</div> </div> <div class="" ng-if="matchSummary.Comments==\'\' && matchSummary.CurrentInnings == \'1\'" ng-bind="matchSummary.TossDetails"></div> <div class="" ng-if="matchSummary.BreakComments!=\'\'" ng-bind="matchSummary.BreakComments"></div> <div ng-if="matchSummary.IsMatchEnd != undefined && matchSummary.IsMatchEnd != 1 && (matchSummary.IsSuperOver != \'1\' || matchSummary.T20LiteSuperOver == \'1\')"> <div ng-if="!checkMatchEnd(matchSummary.MatchID)"> <div ng-if="matchSummary.Target != \'\' && matchSummary.Target != 0 && matchSummary.RevisedTarget == \'\'">Target - {{matchSummary.Target}}</div> <div ng-if="matchSummary.RevisedTarget != \'\' && matchSummary.MatchType != \'Multi Day\'">Revised Target - {{matchSummary.RevisedTarget}}</div> <div class="" ng-if="matchSummary.ChasingText != \'\'">{{matchSummary.ChasingText}}</div> </div> </div> <div ng-if="(matchSummary.IsSuperOver != \'1\' || matchSummary.T20LiteSuperOver == \'1\') && matchSummary.IsMatchEnd == 1"> <div ng-if="matchSummary.RevisedTarget != \'\' && matchSummary.MatchType != \'Multi Day\'">Revised Target - {{matchSummary.RevisedTarget}}</div> </div> <div ng-if="superOverSummary.IsMatchEnd != 1 && matchSummary.IsSuperOver == \'1\' && matchSummary.T20LiteSuperOver != \'1\'"> <div ng-if="superOverSummary.Target != \'\' && superOverSummary.Target != 0 && superOverSummary.RevisedTarget == \'\'">Target - {{superOverSummary.Target}}</div> <div ng-if="superOverSummary.RevisedTarget != \'\' && superOverSummary.MatchType != \'Multi Day\'">Revised Target - {{superOverSummary.RevisedTarget}}</div> <div class="" ng-if="superOverSummary.ChasingText != \'\'">{{superOverSummary.ChasingText}}</div> </div> </div> </div> <div class="teamScores"> <div class="col s6 m12 l3 teamL alignC"> <span class="tLogo"> <img ng-if="isNotNull(matchSummary.FirstBattingTeamLogo)" ng-src="{{matchSummary.FirstBattingTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{matchSummary.FirstBattingTeam}}" /> <img ng-if="!isNotNull(matchSummary.FirstBattingTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{matchSummary.FirstBattingTeam}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{matchSummary.FirstBattingTeam}}" /><img ng-if="!isNotNull(matchSummary.FirstBattingTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{matchSummary.FirstBattingTeam}}" /> </span> <span class="tName" ng-bind="matchSummary.FirstBattingTeam"></span> </div><div class="col s6 m12 l3 teamR alignC"> <span class="tLogo"> <img ng-if="isNotNull(matchSummary.SecondBattingTeamLogo)" ng-src="{{matchSummary.SecondBattingTeamLogo}}" onerror="this.src = basePath+\'images/default-team-logo.png\';" alt="{{matchSummary.SecondBattingTeam}}" /> <img ng-if="!isNotNull(matchSummary.SecondBattingTeamLogo) && DisplayLocalTeamLogo" ng-src="{{localTeamLogoPath}}/{{matchSummary.SecondBattingTeam}}.png" onerror="this.src = basePath+\'images/default-team-logo.png\';" /><img ng-if="!isNotNull(matchSummary.SecondBattingTeamLogo) && !DisplayLocalTeamLogo" ng-src="{{basepath}}images/default-team-logo.png" alt="{{matchSummary.SecondBattingTeam}}" /> </span> <span class="tName" ng-bind="matchSummary.SecondBattingTeam"></span> </div> <div class="col s12 m12 l6"> <div class="innings"><p class="teamScore alignR" ng-class="{activeInn : matchSummary.CurrentInnings==1}"><span class="runs" ng-if="matchSummary[\'1FallScore\'] != \'\'">{{matchSummary[\'1FallScore\']}}/{{matchSummary[\'1FallWickets\']}}<span class="declare" ng-if="matchSummary[\'Innings1Declare\'] == \'1\'"> Dec</span></span><span class="runs" ng-if="matchSummary[\'1FallScore\'] == \'\'">-/-</span><span class="overs" ng-if="matchSummary[\'1FallOvers\'] != \'\'">{{matchSummary[\'1FallOvers\']}} ov</span><span class="runRate hide" ng-if="matchSummary[\'1RunRate\'] != \'\'">RR {{matchSummary[\'1RunRate\']}}</span></p><p class="vs" ng-if="matchSummary.MatchType !=\'Twenty20 Match\' && matchSummary.CurrentInnings > 2">INN - 1</p><p class="vs" ng-if="matchSummary.MatchType ==\'Twenty20 Match\' && matchSummary.CurrentInnings > 2">INN</p><p class="teamScore alignL" ng-class="{activeInn : matchSummary.CurrentInnings==2}"><span class="runs" ng-if="matchSummary[\'2FallScore\'] != \'\'">{{matchSummary[\'2FallScore\']}}/{{matchSummary[\'2FallWickets\']}}<span class="declare" ng-if="matchSummary[\'Innings2Declare\'] == \'1\'"> Dec</span></span><span class="runs" ng-if="matchSummary[\'2FallScore\'] == \'\'">-/-</span><span class="overs" ng-if="matchSummary[\'2FallOvers\'] != \'\'">{{matchSummary[\'2FallOvers\']}} ov</span><span class="runRate hide" ng-if="matchSummary[\'2RunRate\'] != \'\'">RR {{matchSummary[\'2RunRate\']}}</span></p> </div> <div class="innings alignC no-border" ng-if="matchSummary.CurrentInnings > 2 && (matchSummary.IsSuperOver != \'1\' || matchSummary.T20LiteSuperOver == \'1\')"><p class="teamScore alignR" ng-class="{activeInn : (matchSummary.CurrentInnings==3 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsFirstBattingID)}" ng-if="matchSummary.FirstBattingTeamID == matchSummary.SecondInningsFirstBattingID"><span class="runs" ng-if="matchSummary[\'3FallScore\'] != \'\'">{{matchSummary[\'3FallScore\']}}/{{matchSummary[\'3FallWickets\']}}<span class="declare" ng-if="matchSummary[\'Innings3Declare\'] == \'1\'"> Dec</span></span><span class="runs" ng-if="matchSummary[\'3FallScore\'] == \'\'">-/-</span><span class="overs" ng-if="matchSummary[\'3FallOvers\'] != \'\'">{{matchSummary[\'3FallOvers\']}} ov</span><span class="runRate hide" ng-if="matchSummary[\'3RunRate\'] != \'\'">RR {{matchSummary[\'3RunRate\']}}</span></p><p class="teamScore alignR" ng-class="{activeInn : (matchSummary.CurrentInnings==4 && matchSummary.FirstBattingTeamID == matchSummary.SecondInningsSecondBattingID)}" ng-if="matchSummary.FirstBattingTeamID == matchSummary.SecondInningsSecondBattingID"><span class="runs" ng-if="matchSummary[\'4FallScore\'] != \'\'">{{matchSummary[\'4FallScore\']}}/{{matchSummary[\'4FallWickets\']}}<span class="declare" ng-if="matchSummary[\'Innings4Declare\'] == \'1\'"> Dec</span></span><span class="runs" ng-if="matchSummary[\'4FallScore\'] == \'\'">-/-</span><span class="overs" ng-if="matchSummary[\'4FallOvers\'] != \'\'">{{matchSummary[\'4FallOvers\']}} ov</span><span class="runRate hide" ng-if="matchSummary[\'4RunRate\'] != \'\'">RR {{matchSummary[\'4RunRate\']}}</span></p><p class="teamScore alignR" ng-if="matchSummary.CurrentInnings==3 && matchSummary.SecondBattingTeamID == matchSummary.SecondInningsFirstBattingID"><span class="runs">-/-</span></p><p class="vs" ng-if="matchSummary.MatchType !=\'Twenty20 Match\'">INN - 2</p><p class="vs" ng-if="matchSummary.MatchType ==\'Twenty20 Match\'">SUPER OVER</p><p class="teamScore alignL activeInn" n