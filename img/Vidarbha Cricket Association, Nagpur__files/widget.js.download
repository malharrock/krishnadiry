/******* Start of Control ******/
angular.module('MyApp').controller('mcCtrl', ['$scope','$filter','$compile','mcService','$rootScope',function($scope,$filter,$compile,mcService,$rootScope){
	
	/***** define scope variables******/
	$scope.matchSummary='';
