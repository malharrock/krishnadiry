            $('.manhattan-nav .MHprev').attr('start', nMHprevStart);
            $('.manhattan-nav .MHprev').attr('end', nMHprevEnd);
            $('.manhattan-nav .MHnext').attr('start', MHprevStart + 20);
            $('.manhattan-nav .MHnext').attr('end', MHprevEnd + 20);
